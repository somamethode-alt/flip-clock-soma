function pomoRender(){
  var total=(pomoPhase==='work'?pomoWork:pomoBreak)*60;
  var pct=pomoSecondsLeft/total;
  var circ=2*Math.PI*96; // r=96 → circ=603.19
  var arc=document.getElementById('pomo-arc');
  if(arc){arc.style.strokeDasharray=circ;arc.style.strokeDashoffset=circ*(1-pct);}
  var m=Math.floor(pomoSecondsLeft/60),s=pomoSecondsLeft%60;
  var te=document.getElementById('pomo-time'),pe=document.getElementById('pomo-phase');
  if(te)te.textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  if(pe)pe.textContent=pomoPhase==='work'?'✦ Focus':'✦ Pause';
  var hint=document.getElementById('pomo-tap-hint');
  if(hint)hint.textContent=pomoRunning?'':'appuie pour '+(pomoPhase==='work'?'lancer':'commencer la pause');
