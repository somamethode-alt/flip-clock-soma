// ── FLASHCARD STATE ───────────────────────────
let fcCurrentDeckId = null;
let fcCurrentCards = [];
let fcIdx = 0;
let fcCorrect = 0;
let fcWrong = 0;
let fcFlipped = false;
let fcSessionCards = [];
let fcShowingResult = false;
let newDeckColor = '#8B6BB1';
let editingDeckId = null;
let editingCardIdx = null;

// ── FLASHCARD HELPERS ─────────────────────────
function getAllDecks() {
  const userDecks = S.fcDecks || [];
  return [...BUILTIN_DECKS, ...userDecks];
}

function getDeckById(id) {
  return getAllDecks().find(d => d.id === id);
}

function switchFC(el, tab) {
  document.querySelectorAll('#fc-tabs .tab-btn').forEach(b => b.classList.remove('on'));
  el.classList.add('on');
  document.getElementById('fc-browse').style.display = tab === 'browse' ? 'block' : 'none';
  document.getElementById('fc-session').style.display = tab === 'session' ? 'block' : 'none';
  document.getElementById('fc-stats').style.display = tab === 'stats' ? 'block' : 'none';
  if (tab === 'browse') renderFCDecks();
  if (tab === 'stats') renderFCStats();
  if (tab === 'session' && !fcCurrentDeckId) {
    document.getElementById('fc-session-inner').innerHTML = '<div style="text-align:center;padding:40px;color:var(--text3);font-size:13px;">Selectionne un deck depuis "Mes decks" pour commencer.</div>';
  }
}

function renderFCDecks() {
  const grid = document.getElementById('fc-decks-grid');
  if (!grid) return;
  const decks = getAllDecks();
  const userDecks = S.fcDecks || [];

  let html = '<div class="deck-grid">';
  decks.forEach(d => {
    const total = d.cards ? d.cards.length : 0;
    const progress = S.fcProgress?.[d.id] || {};
    const mastered = Object.values(progress).filter(v => v >= 2).length;
    const isOfficial = d.official;
    html += `<div class="deck-card ${isOfficial ? 'deck-card-official' : ''}" style="background:${d.color};" onclick="startDeck('${d.id}')">
      ${isOfficial ? '<div class="deck-card-badge">DEAP 2021</div>' : ''}
      <div>
        <div class="deck-card-title">${d.name}</div>
        <div class="deck-card-count">${total} carte${total > 1 ? 's' : ''}</div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px;">
        <div style="font-size:10px;opacity:.8;">${mastered}/${total} maitrisees</div>
        ${d.official ? '' : `<button onclick="event.stopPropagation();openAddCard('${d.id}')" style="background:rgba(255,255,255,.2);border:none;color:white;border-radius:8px;padding:3px 9px;font-size:10px;cursor:pointer;">+ Carte</button>`}
      </div>
      ${total > 0 ? `<div style="height:2px;background:rgba(255,255,255,.2);border-radius:2px;margin-top:8px;overflow:hidden;"><div style="height:100%;width:${Math.round(mastered/total*100)}%;background:rgba(255,255,255,.7);border-radius:2px;"></div></div>` : ''}
    </div>`;
  });

  // Add button
  html += `<div class="deck-card deck-card-add" onclick="openCreateDeck()" style="min-height:110px;">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    <div>Creer un deck</div>
  </div>`;
  html += '</div>';

  grid.innerHTML = html;
}

function startDeck(deckId) {
  const deck = getDeckById(deckId);
  if (!deck || !deck.cards || deck.cards.length === 0) {
    notif('Ce deck est vide. Ajoute des cartes !');
    return;
  }
  fcCurrentDeckId = deckId;
  // Shuffle
  fcSessionCards = [...deck.cards].sort(() => Math.random() - .5);
  fcIdx = 0;
  fcCorrect = 0;
  fcWrong = 0;
  fcFlipped = false;
  fcShowingResult = false;

  // Switch to session tab
  const tabs = document.querySelectorAll('#fc-tabs .tab-btn');
  tabs.forEach(t => t.classList.remove('on'));
  tabs[1].classList.add('on');
  document.getElementById('fc-browse').style.display = 'none';
  document.getElementById('fc-session').style.display = 'block';
  document.getElementById('fc-stats').style.display = 'none';
  renderFCSession();
}

function renderFCSession() {
  const container = document.getElementById('fc-session-inner');
  if (!container) return;

  if (fcShowingResult) {
    renderFCResult(container);
    return;
  }

  const card = fcSessionCards[fcIdx];
  const total = fcSessionCards.length;
  const deck = getDeckById(fcCurrentDeckId);
  const pct = Math.round(fcIdx / total * 100);

  container.innerHTML = `
    <div style="margin-bottom:14px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <div style="font-size:12px;font-weight:700;color:var(--text2);">${deck ? deck.name : ''}</div>
        <div style="font-size:11px;color:var(--text3);">${fcIdx + 1} / ${total}</div>
      </div>
      <div class="fc-progress-bar"><div class="fc-progress-fill" style="width:${pct}%;"></div></div>
    </div>

    <div class="fc-scene" onclick="flipCard()">
      <div class="fc-card-3d" id="fc-card-3d">
        <div class="fc-face fc-front">
          <div class="fc-face-label">Question</div>
          <div class="fc-face-text" style="color:var(--text);">${card.q}</div>
        </div>
        <div class="fc-face fc-back">
          <div class="fc-face-label">Reponse</div>
          <div class="fc-face-text">${card.a}</div>
        </div>
      </div>
    </div>

    <div class="fc-hint" id="fc-hint">
      <div class="fc-hint-dot"></div>
      Clique sur la carte pour voir la reponse
    </div>

    <div class="fc-controls" id="fc-controls" style="display:none;">
      <button class="fc-btn-wrong" onclick="fcAnswer(false)">Je ne savais pas</button>
      <button class="fc-btn-ok" onclick="fcAnswer(true)">Je savais !</button>
    </div>
  `;
  fcFlipped = false;
}

function flipCard() {
  const card3d = document.getElementById('fc-card-3d');
  if (!card3d) return;
  fcFlipped = !fcFlipped;
  card3d.classList.toggle('flipped', fcFlipped);
  if (fcFlipped) {
    document.getElementById('fc-hint').style.display = 'none';
    document.getElementById('fc-controls').style.display = 'flex';
  } else {
    document.getElementById('fc-hint').style.display = 'flex';
    document.getElementById('fc-controls').style.display = 'none';
  }
}

function fcAnswer(correct) {
  // Update progress
  if (!S.fcProgress) S.fcProgress = {};
  if (!S.fcProgress[fcCurrentDeckId]) S.fcProgress[fcCurrentDeckId] = {};
  const cardKey = fcIdx.toString();
  const current = S.fcProgress[fcCurrentDeckId][cardKey] || 0;
  S.fcProgress[fcCurrentDeckId][cardKey] = correct ? Math.min(3, current + 1) : Math.max(0, current - 1);
  save();

  if (correct) fcCorrect++; else fcWrong++;
  fcIdx++;

  if (fcIdx >= fcSessionCards.length) {
    fcShowingResult = true;
    renderFCSession();
  } else {
    fcFlipped = false;
    renderFCSession();
  }
}

function renderFCResult(container) {
  const total = fcSessionCards.length;
  const pct = Math.round(fcCorrect / total * 100);
  const msgs = ['Continue, tu vas y arriver !', 'Pas mal, continue !', 'Bien joue !', 'Tres bien !', 'Parfait !'];
  const msg = msgs[Math.min(4, Math.floor(pct / 25))];
  const deck = getDeckById(fcCurrentDeckId);

  container.innerHTML = `
    <div style="text-align:center;padding:24px 16px;">
      <div style="font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:2px;margin-bottom:14px;">Fin du deck</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:64px;color:var(--accent);line-height:1;">${fcCorrect}/${total}</div>
      <div style="font-size:14px;color:var(--text2);margin-top:6px;margin-bottom:24px;">${msg}</div>
      <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:20px;">
        <div style="background:rgba(74,156,106,.1);border-radius:12px;padding:12px 18px;text-align:center;">
          <div style="font-size:22px;font-weight:700;color:#4A9C6A;">${fcCorrect}</div>
          <div style="font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;">Reussies</div>
        </div>
        <div style="background:rgba(196,112,106,.1);border-radius:12px;padding:12px 18px;text-align:center;">
          <div style="font-size:22px;font-weight:700;color:#B85550;">${fcWrong}</div>
          <div style="font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;">A retravailler</div>
        </div>
      </div>
      <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
        <button class="btn btn-primary" onclick="startDeck('${fcCurrentDeckId}')">Recommencer</button>
        <button class="btn" onclick="switchFC(document.querySelector('#fc-tabs .tab-btn'),'browse');renderFCDecks()">Changer de deck</button>
      </div>
    </div>
  `;
}

function renderFCStats() {
  const container = document.getElementById('fc-stats-inner');
  if (!container) return;
  const decks = getAllDecks();
  const progress = S.fcProgress || {};
  let totalCards = 0, totalMastered = 0;
  decks.forEach(d => {
    totalCards += d.cards ? d.cards.length : 0;
    const p = progress[d.id] || {};
    totalMastered += Object.values(p).filter(v => v >= 2).length;
  });

  container.innerHTML = `
    <div class="stats-grid" style="margin-bottom:20px;">
      <div class="stat-card"><div class="stat-val">${totalCards}</div><div class="stat-lbl">Cartes au total</div></div>
      <div class="stat-card"><div class="stat-val">${totalMastered}</div><div class="stat-lbl">Maitrisees</div></div>
      <div class="stat-card"><div class="stat-val">${totalCards > 0 ? Math.round(totalMastered/totalCards*100) : 0}%</div><div class="stat-lbl">Progression</div></div>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;">
      ${decks.map(d => {
        const total = d.cards ? d.cards.length : 0;
        const p = progress[d.id] || {};
        const mastered = Object.values(p).filter(v => v >= 2).length;
        const pct = total > 0 ? Math.round(mastered/total*100) : 0;
        return `<div style="background:var(--surface);border-radius:14px;border:1px solid var(--border);padding:14px;display:flex;align-items:center;gap:12px;">
          <div style="width:10px;height:44px;border-radius:5px;background:${d.color};flex-shrink:0;"></div>
          <div style="flex:1;min-width:0;">
            <div style="font-size:12px;font-weight:700;color:var(--text);margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${d.name}</div>
            <div style="height:6px;background:var(--surface3);border-radius:3px;overflow:hidden;"><div style="height:100%;width:${pct}%;background:${d.color};border-radius:3px;transition:width .5s;"></div></div>
          </div>
          <div style="font-size:12px;font-weight:700;color:var(--text3);flex-shrink:0;">${mastered}/${total}</div>
        </div>`;
      }).join('')}
    </div>
  `;
}

// ── CREATE/EDIT DECK ──────────────────────────
function openCreateDeck() {
  document.getElementById('dk-name').value = '';
  document.getElementById('dk-module').value = 'perso';
  newDeckColor = '#8B6BB1';
  document.querySelectorAll('.dk-color-opt').forEach(el => {
    el.style.border = el.dataset.c === newDeckColor ? '3px solid var(--text)' : '3px solid transparent';
  });
  openOv('ov-deck');
}
function selDkColor(el) {
  newDeckColor = el.dataset.c;
  document.querySelectorAll('.dk-color-opt').forEach(e => e.style.border = '3px solid transparent');
  el.style.border = '3px solid var(--text)';
}
function saveDeck() {
  const name = document.getElementById('dk-name').value.trim();
  if (!name) { notif('Donne un nom a ton deck.'); return; }
  if (!S.fcDecks) S.fcDecks = [];
  S.fcDecks.push({
    id: 'deck_' + Date.now(),
    name,
    module: document.getElementById('dk-module').value,
    color: newDeckColor,
    official: false,
    cards: []
  });
  save();
  closeOv('ov-deck');
  notif('Deck "' + name + '" cree !');
  renderFCDecks();
}

// ── ADD CARD TO DECK ──────────────────────────
function openAddCard(deckId) {
  editingDeckId = deckId;
  editingCardIdx = null;
  document.getElementById('fc-recto').value = '';
  document.getElementById('fc-verso').value = '';
  document.getElementById('ov-card-title').textContent = 'Nouvelle carte';
  openOv('ov-card');
}
function saveCard() {
  const q = document.getElementById('fc-recto').value.trim();
  const a = document.getElementById('fc-verso').value.trim();
  if (!q || !a) { notif('Recto et verso sont requis.'); return; }
  if (!S.fcDecks) S.fcDecks = [];
  const deck = S.fcDecks.find(d => d.id === editingDeckId);
  if (!deck) { notif('Deck introuvable.'); return; }
  if (!deck.cards) deck.cards = [];
  deck.cards.push({ q, a });
  save();
  closeOv('ov-card');
  notif('Carte ajoutee !');
  renderFCDecks();
}

// Keyboard navigation for flashcards
document.addEventListener('keydown', e => {
  const page = document.getElementById('page-flashcards');
  if (!page || !page.classList.contains('active')) return;
  if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); flipCard(); }
  if (e.key === 'ArrowRight' && fcFlipped) fcAnswer(true);
  if (e.key === 'ArrowLeft' && fcFlipped) fcAnswer(false);
});


