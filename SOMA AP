function renderQzFiches(){const sel=document.getElementById('qz-fiche');if(!sel)return;sel.innerHTML='<option value="">Selectionner...</option>';S.fiches.forEach(f=>sel.innerHTML+=`<option value="${f.id}">${f.titre}</option>`);}
async function startQuiz(){
  const ficheId=document.getElementById('qz-fiche').value;const sujet=document.getElementById('qz-sujet').value.trim();
  const nb=parseInt(document.getElementById('qz-nb').value);const key=getApiKey();
  const errEl=document.getElementById('qz-error');errEl.style.display='none';
  if(!key){errEl.textContent='Renseigne ta cle API Anthropic.';errEl.style.display='block';return;}
  lsSet('soma_key_'+S.user,key);
  let ctx='';
  if(ficheId){const f=S.fiches.find(x=>x.id==ficheId);if(f)ctx='Fiche : '+f.titre+(f.contenu?'\n\n'+f.contenu:'');}
  else if(sujet)ctx='Sujet : '+sujet+' (AP, referentiel DEAP 2021)';
  else{notif('Selectionne une fiche ou saisis un sujet.');return;}
  document.getElementById('qz-loading').style.display='block';document.getElementById('qz-btn').disabled=true;
  const sys='Tu es formateur expert en auxiliaire de puericulture (referentiel DEAP 2021 France). Genere exactement '+nb+' QCM. JSON uniquement, sans markdown. Format : {"questions":[{"q":"?","options":["A","B","C","D"],"correct":0,"explication":"...","theme":"sujet"}]}';
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':key,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:2000,system:sys,messages:[{role:'user',content:ctx}]})});
    const data=await res.json();if(!res.ok||data.error)throw new Error(data.error?.message||'Erreur '+res.status);
    const txt=data.content.map(c=>c.text||'').join('').replace(/^```json\s*/,'').replace(/\s*```$/,'').trim();
    qzQ=JSON.parse(txt).questions;qzIdx=0;qzScore=0;qzWrong=[];
    document.getElementById('qz-loading').style.display='none';document.getElementById('quiz-setup').style.display='none';document.getElementById('quiz-session').style.display='block';showQ();
  }catch(err){document.getElementById('qz-loading').style.display='none';document.getElementById('qz-btn').disabled=false;errEl.textContent='Erreur : '+err.message;errEl.style.display='block';}
}
function showQ(){if(qzIdx>=qzQ.length){showResult();return;}const q=qzQ[qzIdx];document.getElementById('qz-prog').textContent='Question '+(qzIdx+1)+' / '+qzQ.length;document.getElementById('qz-q').textContent=q.q;document.getElementById('qz-expl').style.display='none';document.getElementById('qz-next').style.display='none';document.getElementById('qz-opts').innerHTML=q.options.map((o,i)=>`<div class="quiz-opt" onclick="ansQ(${i})">${o}</div>`).join('');}
function ansQ(c){const q=qzQ[qzIdx];document.querySelectorAll('.quiz-opt').forEach(o=>o.classList.add('disabled'));document.querySelectorAll('.quiz-opt')[q.correct].classList.add('correct');if(c!==q.correct){document.querySelectorAll('.quiz-opt')[c].classList.add('wrong');qzWrong.push(q.theme||q.q.substring(0,30));}else qzScore++;const ex=document.getElementById('qz-expl');ex.textContent=q.explication;ex.style.display='block';const btn=document.getElementById('qz-next');btn.style.display='inline-flex';btn.textContent=qzIdx+1<qzQ.length?'Suivant':' Voir mon resultat';}
function nextQ(){qzIdx++;showQ();}
function showResult(){
  document.getElementById('quiz-session').style.display='none';document.getElementById('quiz-result').style.display='block';
  const pct=Math.round(qzScore/qzQ.length*100);
  document.getElementById('qz-score').textContent=qzScore+'/'+qzQ.length;
  document.getElementById('qz-msg').textContent=['Continue !','Bien joue !','Tres bien !','Excellent !','Parfait !'][Math.min(4,Math.floor(pct/25))];
  S.quizHistory.push({date:new Date().toISOString(),score:qzScore,total:qzQ.length,wrong:qzWrong,pct});
  if(qzWrong.length)S.weaknesses=[...new Set([...S.weaknesses,...qzWrong])].slice(0,15);
  save();
  if(qzWrong.length)document.getElementById('qz-weaknesses').innerHTML='<div style="background:rgba(196,112,106,.08);border-radius:11px;padding:11px;border-left:3px solid #B85550;margin-top:4px;"><div style="font-size:10px;font-weight:700;color:#B85550;text-transform:uppercase;letter-spacing:1px;margin-bottom:5px;">Points a retravailler</div>'+qzWrong.map(w=>'<div style="font-size:12px;color:var(--text2);padding:2px 0;">— '+w+'</div>').join('')+'</div>';
  
}
function resetQuiz(){qzQ=[];qzIdx=0;qzScore=0;qzWrong=[];document.getElementById('quiz-setup').style.display='block';document.getElementById('qz-btn').disabled=false;['quiz-session','quiz-result','qz-error'].forEach(id=>document.getElementById(id).style.display='none');document.getElementById('qz-weaknesses').innerHTML='';}

