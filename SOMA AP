var pomoQuoteTimer=null;

function initPomoPage(){
  var saved=parseInt(lsGet('soma_pomo_theme')||'0');
  if(!isNaN(saved)&&saved>=0&&saved<POMO_THEMES.length)pomoThemeIdx=saved;
  pomoRender();
  updatePomoOrbs();
  // Quote initiale aléatoire
  var arr=POMO_QUOTES_FOCUS;
  pomoQuoteIdx=Math.floor(Math.random()*arr.length);
  var el=document.getElementById('pomo-quote-text');
  if(el)el.textContent=arr[pomoQuoteIdx];
  // Rotation des citations toutes les 30s
  if(pomoQuoteTimer)clearInterval(pomoQuoteTimer);
  pomoQuoteTimer=setInterval(rotatePomoQuote,30000);
}

function rotatePomoQuote(){
  var arr=pomoPhase==='break'?POMO_QUOTES_BREAK:POMO_QUOTES_FOCUS;
  pomoQuoteIdx=(pomoQuoteIdx+1)%arr.length;
  var el=document.getElementById('pomo-quote-text');
  if(!el)return;
  el.style.animation='none';
  void el.offsetWidth;
  el.style.animation='pomoQuoteIn .7s ease';
  el.textContent=arr[pomoQuoteIdx];
}

function updatePomoOrbs(){
  var theme=POMO_THEMES[pomoThemeIdx]||POMO_THEMES[0];
  var isBreak=pomoPhase==='break';
  var palette=isBreak?theme.brk:theme.focus;
  var bg=isBreak?theme.bgb:theme.bg;
  var o1=document.getElementById('pomo-orb-1');
  var o2=document.getElementById('pomo-orb-2');
  var o3=document.getElementById('pomo-orb-3');
  var sc=document.getElementById('pomo-scene');
  if(o1)o1.style.background='radial-gradient(circle at 40% 40%,'+palette[0]+' 0%,transparent 70%)';
  if(o2)o2.style.background='radial-gradient(circle at 60% 60%,'+palette[1]+' 0%,transparent 70%)';
  if(o3)o3.style.background='radial-gradient(circle at 50% 50%,'+palette[2]+' 0%,transparent 70%)';
  if(sc)sc.style.background=bg;
  if(sc)sc.classList.toggle('is-break',isBreak);
}

function setPomoTheme(idx){
  pomoThemeIdx=idx;
  lsSet('soma_pomo_theme',idx);
  updatePomoOrbs();
  document.querySelectorAll('.pomo-theme-swatch').forEach(function(s,i){s.classList.toggle('active',i===idx);});
}

