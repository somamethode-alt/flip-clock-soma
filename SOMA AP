function spDoImport(input){
  const file = input.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try{
      const data = JSON.parse(e.target.result);
      if(!data.version || !data.data) throw new Error('Format invalide');
      Object.assign(S, data.data);
      if(data.theme) lsSet('soma_theme', data.theme);
      if(data.palette >= 0){ S.paletteIdx = data.palette; applyCSSPalette(data.palette); }
      if(data.plannerFont){ plannerFont = data.plannerFont; lsSet('planner_font', plannerFont); }
      save();
      spRefreshAll();
      notif('Données importées avec succès !');
    }catch(err){
      notif('Fichier invalide : '+err.message);
    }
    input.value = '';
  };
  reader.readAsText(file);
}

