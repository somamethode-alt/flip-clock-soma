function annSearchFR() {
  const q = (document.getElementById('ann-q')?.value || '').trim().toLowerCase();
  const resZone = document.getElementById('ann-search-results');
  if (!q) { if(resZone) resZone.style.display = 'none'; return; }
  const res = S.annuaire.filter(e =>
    e.nom.toLowerCase().includes(q) ||
    (e.addr||'').toLowerCase().includes(q) ||
    e.type.toLowerCase().includes(q) ||
    (DEPT_NAMES[e.dept]||'').toLowerCase().includes(q)
  );
  if (!resZone) return;
  if (res.length === 0) {
    resZone.innerHTML = '<div style="font-size:12px;color:var(--text3);padding:8px 0;">Aucun resultat.</div>';
  } else {
    resZone.innerHTML = res.map(e => {
      const st = '★'.repeat(e.note)+'☆'.repeat(5-e.note);
      return `<div class="etab-row"><div class="etab-icon" style="background:${MAP_COLORS[e.type]||'#8B6BB1'};">${e.type.substring(0,2).toUpperCase()}</div><div style="flex:1;"><div style="font-size:13px;font-weight:700;color:var(--text);">${e.nom}</div><div style="font-size:10px;color:var(--text3);">${DEPT_NAMES[e.dept]||e.dept} · ${e.addr||''}</div><div class="stars" style="margin-top:3px;">${st}</div></div></div>`;
    }).join('');
  }
  resZone.style.display = 'block';
}

