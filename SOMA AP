''}${s.fin?' au '+new Date(s.fin).toLocaleDateString('fr-FR'):''}</div>${s.tuteur?'<div style="font-size:12px;color:#9B87B8;">Tuteur : '+s.tuteur+'</div>':''}</div></div>${s.objectifs.length?'<h2>Objectifs</h2>'+s.objectifs.map(o=>'<div style="padding:5px 9px;background:'+(o.done?'#e8f5ec':'#F3EEF9')+';border-radius:7px;margin-bottom:4px;font-size:12px;"><span style="color:'+(o.done?'#3A7A52':'#8B6BB1')+';font-weight:700;">'+(o.done?'Atteint':'En cours')+'</span> — '+o.text+'</div>').join(''):''}${s.journal.length?'<h2>Journal de stage</h2><table><thead><tr><th>Date</th><th>Activite</th><th>Tuteur</th><th>Heures</th></tr></thead><tbody>'+s.journal.map(j=>'<tr><td>'+j.date+'</td><td>'+j.act+'</td><td>'+j.tut+'</td><td style="text-align:center;font-weight:700;">'+j.h+'h</td></tr>').join('')+'</tbody></table>':''}<footer>SOMA — Auxiliaire de Puericulture · Copyright © ${new Date().getFullYear()}</footer></body></html>`;}
function exportStagePDF(id){const s=S.stages.find(x=>x.id===id)||S.stages.find(x=>x.id===activeStageId);if(!s)return;const blob=new Blob([buildBilanHTML(s)],{type:'text/html'});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='bilan-'+s.etab.replace(/\s+/g,'-').toLowerCase()+'.html';a.click();URL.revokeObjectURL(url);notif('Bilan exporté en HTML — ouvre dans le navigateur puis Fichier › Imprimer › PDF');}

// ── CANDIDATURES ──────────────────────────────
function dtAdd(ds,days){const d=new Date(ds);d.setDate(d.getDate()+days);return d.toLocaleDateString('fr-FR');}
function isPast(ds,days){const d=new Date(ds);d.setDate(d.getDate()+days);return new Date()>d;}
const MAIL_V=[(c,p)=>`Madame, Monsieur,\n\nEtudiante en formation d'Auxiliaire de Puericulture, je me permets de revenir vers vous suite a ma candidature transmise le ${new Date(c.date).toLocaleDateString('fr-FR')} pour la periode ${c.periode||'a convenir'}.\n\nTres motivee par votre etablissement, je reste disponible pour tout entretien.\n\nCordialement,\n${p}`,(c,p)=>`Madame, Monsieur,\n\nJe me permets de vous recontacter au sujet de ma demande de stage en AP, envoyee le ${new Date(c.date).toLocaleDateString('fr-FR')}.\n\nSouhaitant realiser cette periode${c.periode?' ('+c.periode+')':''} dans votre structure, je serais ravie de vous rencontrer.\n\n${p}`,(c,p)=>`Madame, Monsieur,\n\nJe renouvelle mon interet pour un stage AP au sein de votre etablissement, suite a ma candidature du ${new Date(c.date).toLocaleDateString('fr-FR')}.\n\nDans l'espoir d'une reponse favorable,\n\n${p}`];
function openCandModal(){document.getElementById('c-date').value=new Date().toISOString().split('T')[0];['c-etab','c-email','c-addr','c-periode'].forEach(id=>document.getElementById(id).value='');openOv('ov-cand');}
function saveCand(){const etab=document.getElementById('c-etab').value.trim();if(!etab){notif('Renseigne le nom.');return;}S.cands.push({id:Date.now(),etab,type:document.getElementById('c-type').value,email:document.getElementById('c-email').value.trim(),addr:document.getElementById('c-addr').value.trim(),periode:document.getElementById('c-periode').value.trim(),date:document.getElementById('c-date').value,delai:parseInt(document.getElementById('c-delai').value),statut:document.getElementById('c-statut').value});save();closeOv('ov-cand');renderCands();notif('Candidature enregistree !');}
function renderCands(){
  const tbody=document.getElementById('cand-body');if(!tbody)return;
  const stCls={envoye:'pill-a',repondu:'pill-d',accepte:'pill-c',refuse:'pill-e'};let hasR=false;
  tbody.innerHTML=S.cands.map((c,i)=>{const late=isPast(c.date,c.delai||14)&&c.statut==='envoye';if(late)hasR=true;return`<tr>
      <td><strong style="font-weight:700;">${c.etab}</strong><div style="font-size:10px;color:var(--text3);">${c.addr||''}</div></td>
      <td style="font-size:11px;">${c.periode||'—'}</td>
      <td style="font-size:11px;">${new Date(c.date).toLocaleDateString('fr-FR')}</td>
      <td><span class="${late?'relance-late':'relance-ok'}">${late?'Depasse · ':''} ${dtAdd(c.date,c.delai||14)}</span></td>
      <td><span class="pill ${stCls[c.statut]||'pill-a'}">${c.statut}</span></td>
      <td>
        <div style="display:flex;gap:5px;align-items:center;">
          <button onclick="setCandReponse(${i},'oui')" style="padding:3px 9px;border-radius:8px;font-size:10px;font-weight:700;border:1.5px solid ${c.reponse==='oui'?'#4A9C6A':'var(--border)'};background:${c.reponse==='oui'?'rgba(74,156,106,.15)':'var(--surface2)'};color:${c.reponse==='oui'?'#3A7A52':'var(--text3)'};cursor:pointer;font-family:Nunito,sans-serif;transition:all .2s;">Oui</button>
          <button onclick="setCandReponse(${i},'non')" style="padding:3px 9px;border-radius:8px;font-size:10px;font-weight:700;border:1.5px solid ${c.reponse==='non'?'#B85550':'var(--border)'};background:${c.reponse==='non'?'rgba(196,112,106,.12)':'var(--surface2)'};color:${c.reponse==='non'?'#B85550':'var(--text3)'};cursor:pointer;font-family:Nunito,sans-serif;transition:all .2s;">Non</button>
        </div>
      </td>
      <td>'+(late?'<button class="btn btn-sm btn-danger" onclick="relancer('+i+')">Relancer</button>':'')+'</td>
    </tr>`}).join('');
  updateDash();if(hasR){const d=document.getElementById('d-relance');d.style.display='block';d.textContent='Relance : '+S.cands.filter(c=>isPast(c.date,c.delai||14)&&c.statut==='envoye').map(c=>c.etab).join(', ');}
}
function relancer(i){const c=S.cands[i];const p=document.getElementById('dash-prenom')?.textContent||'Etudiante';const body=MAIL_V[c.etab.charCodeAt(0)%MAIL_V.length](c,p);window.open('mailto:'+(c.email||'')+'?subject='+encodeURIComponent('Relance stage AP')+'&body='+encodeURIComponent(body),'_blank');notif('Mail de relance ouvert !');}

function setCandReponse(i, rep) {
  const c = S.cands[i];
  if (!c) return;
  const wasNon = c.reponse === 'non';
  c.reponse = c.reponse === rep ? null : rep;
  save();
  renderCands();
  if (rep === 'non' && !wasNon && c.reponse === 'non') {
    showDesistementMessage(c.etab);
  }
}

function showDesistementMessage(etab) {
  const el = document.getElementById('desist-msg');
  if (!el) return;
  document.getElementById('desist-etab').textContent = etab;
  el.classList.remove('desist-show');
  void el.offsetWidth;
  el.classList.add('desist-show');
  setTimeout(() => el.classList.remove('desist-show'), 7000);
}

function checkRelance(){const en=S.cands.filter(c=>isPast(c.date,c.delai||14)&&c.statut==='envoye');if(en.length)notif('Relance recommandee : '+en.map(c=>c.etab).join(', '));}

// ── CALENDRIER ────────────────────────────────
function makeICS(title,desc,d){const fmt=d=>{const p=n=>String(n).padStart(2,'0');return d.getFullYear()+p(d.getMonth()+1)+p(d.getDate())+'T'+p(d.getHours())+p(d.getMinutes())+'00';};const end=new Date(d.getTime()+3600000);return'BEGIN:VCALENDAR\r\nVERSION:2.0\r\nPRODID:-//SOMA//FR\r\nBEGIN:VEVENT\r\nDTSTART:'+fmt(d)+'\r\nDTEND:'+fmt(end)+'\r\nSUMMARY:'+title+'\r\nDESCRIPTION:'+desc+'\r\nEND:VEVENT\r\nEND:VCALENDAR';}
function addCalICS(type){let title,desc,d=new Date();if(type==='stage'){const s=S.stages.find(x=>x.id===activeStageId)||S.stages[0];title='Stage SOMA'+(s?' — '+s.etab:'');desc='Suivi stage AP';if(s?.fin)d=new Date(s.fin);else d.setDate(d.getDate()+30);}else if(type==='relance'){const en=S.cands.find(c=>isPast(c.date,c.delai||14)&&c.statut==='envoye');title='Relance SOMA'+(en?' — '+en.etab:'');desc='Relancer candidature AP';}else{title='Revision SOMA';desc='Session revision DEAP 2021';d.setDate(d.getDate()+1);}const blob=new Blob([makeICS(title,desc,d)],{type:'text/calendar'});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='soma.ics';a.click();URL.revokeObjectURL(url);notif('Fichier .ics telecharge — ouvre pour ajouter au calendrier.');}
function addCalGoogle(type){let title,desc,d=new Date();if(type==='stage'){const s=S.stages.find(x=>x.id===activeStageId)||S.stages[0];title='Stage SOMA'+(s?' — '+s.etab:'');desc='Suivi stage AP';if(s?.fin)d=new Date(s.fin);else d.setDate(d.getDate()+30);}else if(type==='relance'){const en=S.cands.find(c=>isPast(c.date,c.delai||14)&&c.statut==='envoye');title='Relance SOMA'+(en?' — '+en.etab:'');desc='Relancer candidature AP';}else{title='Revision SOMA';desc='DEAP 2021';d.setDate(d.getDate()+1);}const fmt=d=>{const p=n=>String(n).padStart(2,'0');return d.getFullYear()+p(d.getMonth()+1)+p(d.getDate())+'T'+p(d.getHours())+p(d.getMinutes())+'00';};const end=new Date(d.getTime()+3600000);window.open('https://calendar.google.com/calendar/render?action=TEMPLATE&text='+encodeURIComponent(title)+'&dates='+fmt(d)+'/'+fmt(end)+'&details='+encodeURIComponent(desc),'_blank');notif('Google Agenda ouvert — clique sur Enregistrer.');}

// ── CARTE LEAFLET ─────────────────────────────
function initMap(){
  if(somaMap){somaMap.invalidateSize();return;}
  const mapEl=document.getElementById('soma-map');if(!mapEl||!window.L)return;
  somaMap=L.map('soma-map',{center:[48.866,2.35],zoom:12});
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'OpenStreetMap',maxZoom:19}).addTo(somaMap);
  renderMapMarkers();
}
function createMapIcon(type,acceptAP){const color=MAP_COLORS[type]||'#8B6BB1';const border=acceptAP?3:1.5;const bc=acceptAP?'#3A7A52':color;const svg=`<svg xmlns="http://www.w3.org/2000/svg" width="28" height="36" viewBox="0 0 28 36"><ellipse cx="14" cy="34" rx="5" ry="1.8" fill="rgba(0,0,0,.18)"/><path d="M14 2C9 2 5 6 5 11c0 7 9 21 9 21s9-14 9-21c0-5-4-9-9-9z" fill="${color}" stroke="${bc}" stroke-width="${border}"/><circle cx="14" cy="11" r="4.5" fill="white" opacity=".88"/><text x="14" y="15" text-anchor="middle" font-size="6" font-weight="bold" fill="${color}" font-family="Arial">${type.substring(0,2).toUpperCase()}</text></svg>`;return L.divIcon({html:svg,iconSize:[28,36],iconAnchor:[14,36],popupAnchor:[0,-38],className:''});}
function renderMapMarkers(){if(!somaMap)return;somaMapMarkers.forEach(m=>m.remove());somaMapMarkers=[];const filtered=ETABS_GEO.filter(e=>mapFilter==='all'?true:mapFilter==='ap_ok'?e.accept_ap:e.type===mapFilter);filtered.forEach(e=>{const m=L.marker([e.lat,e.lng],{icon:createMapIcon(e.type,e.accept_ap)}).addTo(somaMap);const st='★'.repeat(e.note)+'☆'.repeat(5-e.note);m.bindPopup(`<div style="font-size:13px;font-weight:700;color:#8B6BB1;">${e.nom}</div><div style="font-size:11px;color:#9B87B8;">${e.type}</div><div style="color:#C9A96E;font-size:11px;">${st}</div>${e.accept_ap?'<div style="margin-top:4px;"><span style="background:rgba(74,156,106,.15);color:#3A7A52;padding:2px 7px;border-radius:8px;font-size:10px;font-weight:700;">Accepte les AP</span></div>':''}<div style="font-size:11px;margin-top:5px;font-style:italic;">"${e.avis}"</div>${e.email?'<div style="font-size:10px;margin-top:5px;">'+e.email+'</div>':''}`);somaMapMarkers.push(m);});}
function toggleMapFilter(el,filter){document.querySelectorAll('.map-pill').forEach(p=>p.classList.remove('active'));el.classList.add('active');mapFilter=filter;renderMapMarkers();}
async function setHomeAddr(){const addr=document.getElementById('map-home-addr').value.trim();if(!addr){notif('Saisis ton adresse.');return;}try{const res=await fetch('https://nominatim.openstreetmap.org/search?format=json&q='+encodeURIComponent(addr)+'&limit=1&countrycodes=fr',{headers:{'Accept':'application/json','User-Agent':'SOMA-AP/1.0'}});const data=await res.json();if(!data?.length){notif('Adresse introuvable. Essaie : "12 rue de Paris, Paris"');return;}const {lat,lon}=data[0];if(homeMarker)homeMarker.remove();homeMarker=L.marker([parseFloat(lat),parseFloat(lon)],{icon:L.divIcon({html:'<div style="width:14px;height:14px;background:var(--accent,#8B6BB1);border-radius:50%;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,.3);"></div>',iconSize:[14,14],iconAnchor:[7,7],className:''})}).addTo(somaMap).bindPopup('Mon domicile');somaMap.flyTo([parseFloat(lat),parseFloat(lon)],14,{duration:1.2});lsSet('soma_city_'+S.user,addr);notif('Position localisee !');fetchWeather();}catch(err){notif('Erreur de geolocalisation : '+err.message);}}
function switchMapView(el,view){document.querySelectorAll('.map-tab').forEach(t=>t.classList.remove('on'));el.classList.add('on');document.getElementById('vue-carte').style.display=view==='carte'?'block':'none';document.getElementById('vue-liste').style.display=view==='liste'?'block':'none';if(view==='carte')setTimeout(initMap,80);if(view==='liste'){renderAnnFrance();}}

