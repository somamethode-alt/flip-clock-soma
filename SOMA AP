  const isDark=document.documentElement.getAttribute('data-theme')==='dark';
  if(isDark){el.textContent='';return;}
  el.textContent=`[data-theme="light"]{--accent:${p.accent};--accent2:${p.accent2};--bg:${p.bg};--surface:${p.surface};--surface2:${p.surface2};--text:${p.text};--text2:${p.text};--glow:${p.accent}30;--border:rgba(0,0,0,0.1);--border2:rgba(0,0,0,0.18);--shadow:0 8px 32px ${p.accent}22;--shadow-lg:0 20px 60px ${p.accent}33;--lavender:${p.swatches[3]||p.accent};}`;
}

