function switchToMapAndFly(nom){const tab=document.querySelector('.map-tab');if(tab)switchMapView(tab,'carte');setTimeout(()=>{const e=ETABS_GEO.find(x=>x.nom===nom);if(e&&somaMap)somaMap.flyTo([e.lat,e.lng],16,{duration:1.2});},200);}
function setStars(n){starVal=n;document.querySelectorAll('.avs').forEach(s=>s.style.color=parseInt(s.dataset.v)<=n?'var(--gold)':'var(--border2)');}
function submitAvis(){
  const nom=document.getElementById('av-nom').value.trim();if(!nom){notif('Renseigne le nom.');return;}
  const dept=document.getElementById('av-dept').value;
  S.annuaire.push({nom,type:document.getElementById('av-type').value,dept,addr:document.getElementById('av-addr').value.trim(),note:starVal,avis:document.getElementById('av-txt').value.trim()||'(Avis partage)',auteur:document.getElementById('dash-prenom')?.textContent||'Etudiante'});
  save();const sub=encodeURIComponent('Avis SOMA — '+nom);const body=encodeURIComponent('Etablissement : '+nom+'\nNote : '+starVal+'/5\nAvis :\n'+document.getElementById('av-txt').value);
  window.open('mailto:soma.methode@gmail.com?subject='+sub+'&body='+body,'_blank');
  closeOv('ov-avis');renderAnnContent();notif('Avis publie !');}

