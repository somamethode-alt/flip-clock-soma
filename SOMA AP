// ── WEATHER ───────────────────────────────────
async function fetchWeather(){
  try{
    const city=lsGet('soma_city_'+S.user)||'Paris';
    const geo=await fetch('https://geocoding-api.open-meteo.com/v1/search?name='+encodeURIComponent(city)+'&count=1&language=fr');
    const gd=await geo.json();if(!gd.results?.length)return;
    const {latitude,longitude,name}=gd.results[0];
    const wr=await fetch('https://api.open-meteo.com/v1/forecast?latitude='+latitude+'&longitude='+longitude+'&current_weather=true');
    const wd=await wr.json();
    const t=Math.round(wd.current_weather.temperature);
    const d={0:'Ensoleille',1:'Peu nuageux',2:'Nuageux',3:'Couvert',45:'Brumeux',61:'Pluie',71:'Neige',80:'Averses',95:'Orage'};
    const c=wd.current_weather.weathercode;
    const near=Object.keys(d).map(Number).reduce((a,b)=>Math.abs(b-c)<Math.abs(a-c)?b:a);
    document.getElementById('topbar-weather').textContent=(name||city)+' · '+t+'°C · '+(d[near]||'Variable');
  }catch(e){}
}

