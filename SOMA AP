function updateDash(){
  document.getElementById('d-fiches').textContent=S.fiches.length;
  document.getElementById('d-cands').textContent=S.cands.length;
  const st=S.stages.find(x=>x.id===activeStageId)||S.stages[0];
  if(st){const pct=Math.min(100,Math.round(st.hdone/st.htotal*100));const reste=Math.max(0,st.htotal-st.hdone);document.getElementById('d-pct').textContent=pct+'%';document.getElementById('d-prog').style.width=pct+'%';document.getElementById('d-stage-rappel').textContent=reste===0?'Stage '+st.etab+' valide !':'Stage '+st.etab+' · '+reste+'h restantes';}
}


