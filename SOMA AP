// ═══ AGENDA IFRAME (agenda-v4-test) ═══
const _AGENDA_B64 = "";
let _agendaLoaded = false;

function loadAgendaIframe(){
  if(_agendaLoaded) return;
  const iframe = document.getElementById('agenda-iframe');
  if(!iframe) return;
  // Décoder base64 → string UTF-8 → srcdoc
  // srcdoc fonctionne sans blob URL, pas de problème file:// ni Safari iOS
  const b64 = _AGENDA_B64;
  const bin = atob(b64);
  const bytes = new Uint8Array(bin.length);
  for(let i=0;i<bin.length;i++) bytes[i]=bin.charCodeAt(i);
  const html = new TextDecoder('utf-8').decode(bytes);
  iframe.srcdoc = html;
  _agendaLoaded = true;
}

