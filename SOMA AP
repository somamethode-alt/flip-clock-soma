<title>SŌMA — Auxiliaire de Puericulture</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Nunito:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;}

[data-theme="light"]{
  --bg:#FAF7FF;--surface:#FFFFFF;--surface2:#F3EEF9;--surface3:#EDE5F6;
  --accent:#8B6BB1;--accent2:#C97BA8;--accent3:#B8A0D4;
  --lavender:#D4C5EB;--gold:#C9A96E;--gold2:#E8C47E;
  --text:#1E1428;--text2:#5C4A78;--text3:#9B87B8;
  --border:rgba(139,107,177,0.15);--border2:rgba(139,107,177,0.28);
  --glow:rgba(139,107,177,0.18);
  --shadow:0 8px 32px rgba(139,107,177,0.14);
  --shadow-lg:0 20px 60px rgba(139,107,177,0.22);
}
[data-theme="dark"]{
  --bg:#0E0A16;--surface:#1A1328;--surface2:#231B38;--surface3:#2E2447;
  --accent:#B08FD8;--accent2:#D49AB8;--accent3:#9678C0;
  --lavender:#4A3870;--gold:#D4B07A;--gold2:#F0CC8A;
  --text:#F2ECFF;--text2:#C4AEE8;--text3:#7A6898;
  --border:rgba(176,143,216,0.15);--border2:rgba(176,143,216,0.3);
  --glow:rgba(176,143,216,0.2);
  --shadow:0 8px 32px rgba(0,0,0,0.4);
  --shadow-lg:0 20px 60px rgba(0,0,0,0.5);
}

html,body{height:100%;font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);transition:background .4s,color .4s;}
#landing-screen{height:100%;overflow-y:auto;}

/* LAYOUT */
.app{display:flex;flex-direction:column;height:100vh;position:relative;overflow:hidden;}
.app::before{content:'';position:fixed;top:-120px;right:-80px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(176,143,216,.12) 0%,transparent 70%);pointer-events:none;animation:blob1 8s ease-in-out infinite;}
.app::after{content:'';position:fixed;bottom:-100px;left:-60px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(209,155,176,.1) 0%,transparent 70%);pointer-events:none;animation:blob2 10s ease-in-out infinite;}
@keyframes blob1{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-30px,20px) scale(1.1);}}
@keyframes blob2{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(20px,-30px) scale(1.08);}}

/* TOPBAR */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:0 18px;height:60px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;position:relative;z-index:10;}
.topbar-logo{font-family:'Cormorant Garamond',serif;font-size:24px;letter-spacing:5px;color:var(--accent);font-weight:400;}
.topbar-logo span{color:var(--accent2);}
.topbar-center{font-size:12px;color:var(--text3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;}
.topbar-right{display:flex;align-items:center;gap:8px;}
.icon-btn{width:34px;height:34px;border-radius:50%;border:1px solid var(--border2);background:var(--surface2);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s;color:var(--text2);font-size:14px;}
.icon-btn:hover{background:var(--surface3);transform:scale(1.08);}
.avatar-btn{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));cursor:pointer;border:2px solid var(--border2);overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:13px;color:white;font-weight:500;transition:all .3s;flex-shrink:0;}
.avatar-btn:hover{transform:scale(1.08);}

/* SCROLL */
.main-scroll{flex:1;overflow-y:auto;overflow-x:hidden;padding:0 0 100px;}
.main-scroll::-webkit-scrollbar{width:3px;}
.main-scroll::-webkit-scrollbar-thumb{background:var(--lavender);border-radius:3px;}
.page-inner{padding:20px 18px 8px;}
.page{display:none;}
.page.active{display:block;opacity:1;animation:pageIn .4s cubic-bezier(.34,1.56,.64,1);}
@keyframes pageIn{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}

/* BOTTOM NAV */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;height:72px;background:var(--surface);border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-around;padding:0 2px 6px;z-index:100;backdrop-filter:blur(10px);}
.nav-btn{display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 6px;border-radius:12px;cursor:pointer;border:none;background:transparent;color:var(--text3);font-family:'Nunito',sans-serif;font-size:9px;font-weight:500;transition:all .3s cubic-bezier(.34,1.56,.64,1);min-width:42px;position:relative;}
.nav-btn.active{color:var(--accent);}
.nav-btn.active::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:26px;height:3px;border-radius:0 0 4px 4px;background:linear-gradient(90deg,var(--accent),var(--accent2));}
.nav-btn:hover:not(.active){color:var(--text2);transform:translateY(-2px);}
.nav-icon-wrap{width:20px;height:20px;display:flex;align-items:center;justify-content:center;transition:transform .3s cubic-bezier(.34,1.56,.64,1);}
.nav-btn.active .nav-icon-wrap{transform:scale(1.15);}

/* CARDS */
.card{background:var(--surface);border-radius:18px;border:1px solid var(--border);padding:18px;margin-bottom:14px;transition:all .3s;box-shadow:var(--shadow);}
.card-nohover{background:var(--surface);border-radius:18px;border:1px solid var(--border);padding:18px;margin-bottom:14px;}
.card:hover{box-shadow:var(--shadow-lg);transform:translateY(-2px);}
.card-label{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px;}
.section-title{font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--text);font-weight:400;margin-bottom:4px;line-height:1.2;}
.section-title em{color:var(--accent);font-style:italic;}
.section-sub{font-size:12px;color:var(--text3);margin-bottom:18px;}

/* PILLS */
.pill{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;}
.pill-a{background:rgba(139,107,177,.12);color:var(--accent);}
.pill-b{background:rgba(201,123,168,.12);color:var(--accent2);}
.pill-c{background:rgba(100,180,130,.12);color:#4A9C6A;}
.pill-d{background:rgba(200,168,74,.12);color:var(--gold);}
.pill-e{background:rgba(196,112,106,.12);color:#B85550;}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:5px;padding:9px 18px;border-radius:12px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:600;cursor:pointer;border:1.5px solid var(--border2);background:var(--surface2);color:var(--accent);transition:all .25s;}
.btn:hover{background:var(--surface3);transform:translateY(-1px);box-shadow:var(--shadow);}
.btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;border-color:transparent;box-shadow:0 4px 14px var(--glow);}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 22px var(--glow);}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold2));color:#3A2800;border-color:transparent;}
.btn-sm{padding:5px 12px;font-size:11px;border-radius:9px;}
.btn-danger{background:rgba(196,112,106,.1);color:#B85550;border-color:rgba(196,112,106,.2);}
.btn-danger:hover{background:#B85550;color:white;}
.btn-ghost{background:transparent;border-color:transparent;color:var(--text3);}
.btn-ghost:hover{background:var(--surface2);color:var(--text);}

/* INPUTS */
.input{width:100%;padding:11px 15px;border-radius:12px;border:1.5px solid var(--border);background:var(--surface2);font-family:'Nunito',sans-serif;font-size:13px;color:var(--text);outline:none;transition:all .25s;-webkit-appearance:none;appearance:none;}
.input:focus{border-color:var(--accent);background:var(--surface);box-shadow:0 0 0 3px var(--glow);}
textarea.input{resize:vertical;min-height:80px;}
.input-label{font-size:10px;font-weight:700;color:var(--text3);letter-spacing:1px;text-transform:uppercase;display:block;margin-bottom:5px;}
.form-row{margin-bottom:13px;}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.flex-between{display:flex;justify-content:space-between;align-items:center;}

/* STATS */
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:18px;}
.stat-card{background:var(--surface);border-radius:16px;border:1px solid var(--border);padding:14px;text-align:center;transition:all .3s;position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:-28px;right:-18px;width:70px;height:70px;border-radius:50%;background:var(--glow);transition:transform .3s;}
.stat-card:hover::before{transform:scale(1.5);}
.stat-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg);}
.stat-val{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;color:var(--accent);line-height:1;}
.stat-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin-top:3px;}
.stat-bar{height:3px;background:var(--surface3);border-radius:3px;margin-top:8px;overflow:hidden;}
.stat-bar-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width 1s ease;}

/* TABLE */
.soma-table{width:100%;border-collapse:collapse;font-size:12px;}
.soma-table th{text-align:left;padding:7px 10px;font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--text3);border-bottom:1px solid var(--border);font-weight:700;}
.soma-table td{padding:10px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;}
.soma-table tr:last-child td{border-bottom:none;}
.soma-table tr:hover td{background:var(--surface2);}

/* FICHES */
.bloc-section{margin-bottom:22px;}
.bloc-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--surface);border-radius:14px;border:1px solid var(--border);cursor:pointer;margin-bottom:10px;transition:all .25s;box-shadow:var(--shadow);}
.bloc-header:hover{border-color:var(--border2);box-shadow:var(--shadow-lg);}
.bloc-left{display:flex;align-items:center;gap:10px;}
.bloc-title{font-size:13px;font-weight:700;color:var(--text);}
.bloc-sub{font-size:10px;color:var(--text3);margin-top:1px;}
.bloc-chevron{color:var(--text3);font-size:11px;transition:transform .3s;}
.bloc-chevron.open{transform:rotate(180deg);}
.fiches-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;}
.fiche-card{background:var(--surface);border-radius:14px;border:1px solid var(--border);padding:14px;cursor:pointer;transition:all .3s cubic-bezier(.34,1.56,.64,1);position:relative;overflow:hidden;}
.fiche-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));transform:scaleX(0);transform-origin:left;transition:transform .3s;}
.fiche-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg);border-color:var(--border2);}
.fiche-card:hover::after{transform:scaleX(1);}
.fiche-card-add{border:2px dashed var(--border2);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:5px;min-height:100px;color:var(--text3);font-size:12px;transition:all .25s;background:transparent;}
.fiche-card-add:hover{border-color:var(--accent);color:var(--accent);}
.fiche-handle{position:absolute;top:7px;right:8px;color:var(--border2);font-size:10px;letter-spacing:2px;}
.fiche-tag{display:inline-block;padding:2px 8px;border-radius:8px;font-size:10px;font-weight:600;margin-bottom:7px;}
.fiche-name{font-size:12px;font-weight:700;color:var(--text);margin-bottom:3px;}
.fiche-meta{font-size:10px;color:var(--text3);}
.fiche-preview{font-size:11px;color:var(--text2);margin-top:5px;line-height:1.5;max-height:33px;overflow:hidden;}

/* TABS */
.tabs-row{display:flex;gap:3px;background:var(--surface2);border-radius:12px;padding:3px;margin-bottom:18px;width:fit-content;flex-wrap:wrap;}
.tab-btn{padding:7px 16px;border-radius:9px;font-size:11px;cursor:pointer;color:var(--text3);transition:all .25s;font-weight:500;border:none;background:transparent;font-family:'Nunito',sans-serif;}
.tab-btn.on{background:var(--surface);color:var(--accent);font-weight:700;box-shadow:var(--shadow);}

/* STAGE */
.stage-card{background:var(--surface);border-radius:18px;border:1px solid var(--border);padding:16px;cursor:pointer;transition:all .3s;margin-bottom:10px;display:flex;align-items:center;gap:14px;}
.stage-card:hover{border-color:var(--border2);box-shadow:var(--shadow-lg);transform:translateX(4px);}
.stage-card.sel{border-color:var(--accent);background:var(--surface2);}
.obj-item{display:flex;align-items:flex-start;gap:9px;padding:9px 12px;background:var(--surface2);border-radius:11px;margin-bottom:7px;font-size:13px;transition:background .2s;}
.obj-item:hover{background:var(--surface3);}
.obj-check{width:18px;height:18px;border-radius:5px;border:2px solid var(--border2);cursor:pointer;flex-shrink:0;margin-top:1px;display:flex;align-items:center;justify-content:center;transition:all .25s;font-size:10px;}
.obj-check.done{background:var(--accent);border-color:var(--accent);color:white;}

/* QUIZ */
.quiz-q{font-size:16px;font-weight:600;color:var(--text);line-height:1.6;margin-bottom:18px;}
.quiz-opts{display:flex;flex-direction:column;gap:9px;}
.quiz-opt{padding:12px 16px;border-radius:12px;border:1.5px solid var(--border);cursor:pointer;font-size:13px;color:var(--text);transition:all .25s;background:var(--surface2);font-family:'Nunito',sans-serif;text-align:left;font-weight:500;}
.quiz-opt:hover{border-color:var(--accent);background:var(--surface3);transform:translateX(4px);}
.quiz-opt.correct{background:rgba(100,180,130,.12);border-color:#4A9C6A;color:#3A7A52;}
.quiz-opt.wrong{background:rgba(196,112,106,.1);border-color:#B85550;color:#B85550;}
.quiz-opt.disabled{pointer-events:none;}
.quiz-expl{margin-top:14px;padding:12px 15px;background:var(--surface2);border-radius:12px;border-left:3px solid var(--accent);font-size:13px;color:var(--text2);line-height:1.7;display:none;}

/* IA CHAT */
.soma-chat{display:flex;flex-direction:column;gap:10px;max-height:380px;overflow-y:auto;padding:4px 0;}
.soma-chat::-webkit-scrollbar{width:3px;}
.soma-chat::-webkit-scrollbar-thumb{background:var(--lavender);border-radius:3px;}
.chat-bubble{padding:12px 14px;border-radius:16px;font-size:13px;line-height:1.7;max-width:88%;animation:bubbleIn .3s ease;}
@keyframes bubbleIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.chat-bubble.soma{background:linear-gradient(135deg,rgba(139,107,177,.09),rgba(201,123,168,.05));border:1px solid var(--border);align-self:flex-start;border-bottom-left-radius:4px;color:var(--text);}
.chat-bubble.user{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;align-self:flex-end;border-bottom-right-radius:4px;}
.chat-bubble.soma .chat-sender{font-size:9px;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;}
.chat-input-row{display:flex;gap:8px;margin-top:12px;align-items:flex-end;}
.chat-input-row textarea{flex:1;border-radius:14px;border:1.5px solid var(--border);background:var(--surface2);font-family:'Nunito',sans-serif;font-size:13px;color:var(--text);padding:11px 14px;outline:none;resize:none;min-height:44px;max-height:120px;transition:all .25s;}
.chat-input-row textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--glow);}
.soma-ask-btn{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;border:none;border-radius:12px;padding:11px 16px;font-family:'Nunito',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .25s;white-space:nowrap;display:flex;align-items:center;gap:5px;}
.soma-ask-btn:hover{transform:translateY(-2px);box-shadow:0 6px 16px var(--glow);}
.soma-ask-btn:disabled{opacity:.5;cursor:not-allowed;transform:none;}
.soma-quick-btns{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;}
.soma-quick{padding:6px 12px;border-radius:18px;border:1px solid var(--border2);background:var(--surface2);font-size:11px;color:var(--text2);cursor:pointer;transition:all .2s;font-family:'Nunito',sans-serif;font-weight:500;}
.soma-quick:hover{border-color:var(--accent);background:var(--surface3);color:var(--accent);}
.ai-typing{display:flex;align-items:center;gap:5px;padding:11px 14px;background:var(--surface2);border-radius:16px;border-bottom-left-radius:4px;width:fit-content;border:1px solid var(--border);}
.ai-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);animation:aiDot 1.4s ease-in-out infinite;}
.ai-dot:nth-child(2){animation-delay:.2s;}
.ai-dot:nth-child(3){animation-delay:.4s;}
@keyframes aiDot{0%,80%,100%{transform:scale(.6);opacity:.4;}40%{transform:scale(1);opacity:1;}}

/* REVISIONS */
.rev-week{background:var(--surface);border-radius:14px;border:1px solid var(--border);padding:14px;margin-bottom:9px;}
.rev-topic{display:flex;align-items:center;gap:9px;padding:8px 11px;background:var(--surface2);border-radius:10px;margin-bottom:5px;font-size:12px;cursor:pointer;transition:all .2s;}
.rev-topic:hover{background:var(--surface3);}
.rev-check{width:17px;height:17px;border-radius:5px;border:2px solid var(--border2);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:9px;transition:all .2s;}
.rev-check.done{background:var(--accent);border-color:var(--accent);color:white;}
.rev-priority{padding:2px 8px;border-radius:9px;font-size:9px;font-weight:700;white-space:nowrap;}
.rev-priority.high{background:rgba(196,112,106,.12);color:#B85550;}
.rev-priority.med{background:rgba(200,168,74,.12);color:var(--gold);}
.rev-priority.low{background:rgba(100,180,130,.12);color:#4A9C6A;}

/* PALETTE */
.palette-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:16px;}
.pal-card{border-radius:14px;padding:12px 8px;cursor:pointer;border:2px solid transparent;transition:all .3s;text-align:center;position:relative;}
.pal-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-lg);}
.pal-card.selected{border-color:var(--text) !important;}
.pal-swatches{display:flex;gap:3px;justify-content:center;margin-bottom:6px;}
.pal-swatch{width:18px;height:18px;border-radius:50%;}
.pal-name{font-size:9px;font-weight:600;color:var(--text3);letter-spacing:.5px;}

/* MAP */
.map-tabs{display:flex;gap:3px;background:var(--surface2);border-radius:11px;padding:3px;margin-bottom:14px;width:fit-content;}
.map-tab{padding:7px 18px;border-radius:8px;font-size:12px;cursor:pointer;color:var(--text3);transition:all .25s;font-weight:500;border:none;background:transparent;font-family:'Nunito',sans-serif;}
.map-tab.on{background:var(--surface);color:var(--accent);font-weight:700;box-shadow:var(--shadow);}
.map-container{border-radius:16px;overflow:hidden;border:1px solid var(--border);margin-bottom:14px;}
#soma-map{height:320px;width:100%;}
.map-filters{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;}
.map-pill{padding:4px 12px;border-radius:18px;border:1.5px solid var(--border);background:var(--surface);font-size:11px;color:var(--text2);cursor:pointer;transition:all .2s;font-weight:500;display:flex;align-items:center;gap:4px;}
.map-pill.active{border-color:var(--accent);background:rgba(139,107,177,.1);color:var(--accent);font-weight:700;}
.map-pill-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.etab-row{background:var(--surface);border-radius:14px;border:1px solid var(--border);padding:14px;margin-bottom:9px;display:flex;gap:12px;transition:all .25s;cursor:pointer;position:relative;}
.etab-row:hover{border-color:var(--border2);transform:translateX(3px);}
.etab-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:white;flex-shrink:0;}
.etab-ap-badge{position:absolute;top:10px;right:10px;padding:2px 8px;border-radius:18px;font-size:9px;font-weight:700;background:rgba(100,180,130,.12);color:#3A7A52;border:1px solid rgba(100,180,130,.3);}
.stars{color:var(--gold);font-size:12px;}

/* CANDIDATURES */
.relance-ok{color:#4A9C6A;font-weight:600;font-size:11px;}
.relance-late{color:#B85550;font-weight:600;font-size:11px;}
.cal-export-row{display:flex;gap:7px;flex-wrap:wrap;margin-top:9px;}
.cal-btn{display:flex;align-items:center;gap:5px;padding:7px 12px;border-radius:10px;border:1.5px solid var(--border);background:var(--surface2);font-size:11px;font-family:'Nunito',sans-serif;font-weight:600;cursor:pointer;color:var(--text2);transition:all .25s;}
.cal-btn:hover{border-color:var(--accent);background:var(--surface3);color:var(--accent);}
.cal-btn-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}

/* NOTIF */
.notif{position:fixed;top:72px;right:16px;background:var(--surface);border-radius:16px;padding:12px 15px;max-width:280px;border:1px solid var(--border2);z-index:9999;box-shadow:var(--shadow-lg);display:none;}
.notif.show{display:block;opacity:1;animation:notifIn .4s cubic-bezier(.34,1.56,.64,1);}
@keyframes notifIn{from{opacity:0;transform:translateX(50px) scale(.9);}to{opacity:1;transform:none;}}
.notif-head{display:flex;align-items:center;gap:7px;margin-bottom:5px;}
.notif-dot{width:26px;height:26px;border-radius:7px;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;color:white;font-size:12px;}
.notif-app{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;}
.notif-time{font-size:9px;color:var(--text3);margin-left:auto;}
.notif-msg{font-size:12px;color:var(--text);line-height:1.5;}
.notif-sig{font-size:10px;color:var(--text3);margin-top:3px;font-style:italic;}

/* OVERLAYS */
.overlay{position:fixed;inset:0;background:rgba(10,5,20,.6);z-index:200;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.overlay.open{display:flex;opacity:1;animation:fadeIn .2s ease;}
@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
.modal{background:var(--surface);border-radius:22px;padding:26px;width:92%;max-width:600px;max-height:88vh;overflow-y:auto;border:1px solid var(--border2);animation:modalIn .4s cubic-bezier(.34,1.56,.64,1);position:relative;box-shadow:var(--shadow-lg);}
.modal::-webkit-scrollbar{width:3px;}
.modal::-webkit-scrollbar-thumb{background:var(--lavender);border-radius:3px;}
@keyframes modalIn{from{opacity:0;transform:translateY(24px) scale(.95);}to{opacity:1;transform:none;}}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:21px;color:var(--text);margin-bottom:18px;font-weight:400;}
.modal-x{position:absolute;top:16px;right:16px;width:26px;height:26px;border-radius:50%;border:1px solid var(--border);background:var(--surface2);cursor:pointer;font-size:13px;color:var(--text3);display:flex;align-items:center;justify-content:center;transition:all .2s;}
.modal-x:hover{background:var(--surface3);}

/* FICHE VIEWER */
.fv-bg{position:fixed;inset:0;background:rgba(8,4,16,.88);z-index:600;display:none;align-items:center;justify-content:center;backdrop-filter:blur(6px);}
.fv-bg.open{display:flex;opacity:1;animation:fadeIn .2s ease;}
.fv-inner{background:var(--surface);border-radius:20px;width:92%;max-width:700px;max-height:90vh;overflow-y:auto;border:1px solid var(--border2);position:relative;box-shadow:var(--shadow-lg);animation:modalIn .35s cubic-bezier(.34,1.56,.64,1);}
.fv-header{padding:24px 28px 0;}
.fv-body{padding:0 28px 24px;}
.fv-content{font-size:13px;color:var(--text);line-height:1.9;white-space:pre-wrap;margin-top:14px;background:var(--surface2);padding:16px 18px;border-radius:12px;}

/* BOOK */
.book-overlay{position:fixed;inset:0;background:rgba(8,4,16,.92);z-index:700;display:none;align-items:center;justify-content:center;flex-direction:column;backdrop-filter:blur(8px);}
.book-overlay.open{display:flex;opacity:1;animation:fadeIn .3s ease;}
.book-close{position:absolute;top:22px;right:24px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:white;border-radius:50%;width:36px;height:36px;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.book-close:hover{background:rgba(255,255,255,.2);}
.book-wrap{width:min(540px,90vw);}
.book-page{background:var(--surface);border-radius:8px;padding:44px;min-height:360px;box-shadow:0 28px 70px rgba(0,0,0,.6);position:relative;}
.book-page.turning{animation:pageTurn .35s ease;}
@keyframes pageTurn{0%{opacity:1;transform:perspective(900px) rotateY(0);}40%{opacity:0;transform:perspective(900px) rotateY(-15deg);}60%{opacity:0;transform:perspective(900px) rotateY(10deg);}100%{opacity:1;transform:perspective(900px) rotateY(0);}}
.book-page-title{font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--text);margin-bottom:5px;}
.book-page-meta{font-size:11px;color:var(--text3);margin-bottom:16px;}
.book-page-content{font-size:13px;color:var(--text2);line-height:1.9;white-space:pre-wrap;}
.book-page-num{position:absolute;bottom:18px;left:50%;transform:translateX(-50%);font-size:11px;color:var(--text3);}
.book-arrows{display:flex;gap:18px;margin-top:16px;justify-content:center;}
.book-arrow{width:42px;height:42px;border-radius:50%;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.06);color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;transition:all .25s;}
.book-arrow:hover{background:rgba(255,255,255,.15);}
.book-arrow:disabled{opacity:.2;cursor:default;}
.book-counter{color:rgba(255,255,255,.45);font-size:12px;margin-top:8px;text-align:center;}
.book-hint{color:rgba(255,255,255,.25);font-size:11px;margin-top:4px;text-align:center;}

/* LOGIN */
.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);position:relative;overflow:hidden;}
.login-wrap::before{content:'';position:fixed;top:-200px;right:-200px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(176,143,216,.15) 0%,transparent 70%);pointer-events:none;animation:blob1 8s ease-in-out infinite;}
.login-wrap::after{content:'';position:fixed;bottom:-200px;left:-200px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(201,123,168,.12) 0%,transparent 70%);pointer-events:none;animation:blob2 10s ease-in-out infinite;}
.login-card{background:var(--surface);border-radius:26px;padding:44px 38px;width:min(380px,94vw);border:1px solid var(--border2);text-align:center;box-shadow:var(--shadow-lg);position:relative;z-index:1;animation:modalIn .6s cubic-bezier(.34,1.56,.64,1);}
.login-logo{font-family:'Cormorant Garamond',serif;font-size:44px;color:var(--accent);letter-spacing:8px;display:block;margin-bottom:4px;}
.login-tagline{font-size:10px;color:var(--text3);letter-spacing:3px;text-transform:uppercase;margin-bottom:24px;display:block;}

/* LANDING */
.landing-wrap{min-height:100vh;background:var(--bg);overflow-y:auto;width:100%;box-sizing:border-box;overflow-x:hidden;}
.landing-hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:60px 20px;position:relative;width:100%;box-sizing:border-box;}
.landing-hero::before{content:'';position:fixed;top:-200px;right:-200px;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(176,143,216,.15) 0%,transparent 70%);pointer-events:none;animation:blob1 8s ease-in-out infinite;}
.landing-hero::after{content:'';position:fixed;bottom:-200px;left:-200px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(201,123,168,.12) 0%,transparent 70%);pointer-events:none;animation:blob2 10s ease-in-out infinite;}
.landing-logo{font-family:'Cormorant Garamond',serif;font-size:72px;color:var(--accent);letter-spacing:12px;line-height:1;margin-bottom:10px;animation:fadeUp .8s ease;}
.landing-tagline{font-size:13px;color:var(--text3);letter-spacing:3px;text-transform:uppercase;margin-bottom:8px;animation:fadeUp .8s ease .1s both;}
.landing-headline{font-family:'Cormorant Garamond',serif;font-size:32px;color:var(--text);line-height:1.4;margin:24px 0 16px;max-width:500px;animation:fadeUp .8s ease .2s both;}
.landing-headline em{color:var(--accent);font-style:italic;}
.landing-sub{font-size:14px;color:var(--text2);line-height:1.7;max-width:440px;margin-bottom:36px;animation:fadeUp .8s ease .3s both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
.landing-cta{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;animation:fadeUp .8s ease .4s both;width:100%;}
.landing-features{padding:60px 20px;max-width:900px;margin:0 auto;width:100%;box-sizing:border-box;}
.landing-feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px;margin-top:32px;}
.landing-feat-card{background:var(--surface);border-radius:18px;border:1px solid var(--border);padding:22px;transition:all .3s;}
.landing-feat-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg);}
.landing-feat-icon{width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,rgba(139,107,177,.15),rgba(201,123,168,.1));display:flex;align-items:center;justify-content:center;margin-bottom:14px;}
.landing-feat-title{font-size:15px;font-weight:700;color:var(--text);margin-bottom:6px;}
.landing-feat-desc{font-size:13px;color:var(--text2);line-height:1.6;}
.landing-social{padding:40px 24px 60px;text-align:center;max-width:600px;margin:0 auto;}
.landing-testimonials{display:flex;flex-direction:column;gap:14px;margin-top:24px;}
.landing-testi{background:var(--surface);border-radius:16px;border:1px solid var(--border);padding:18px;text-align:left;}
.landing-testi-txt{font-size:13px;color:var(--text2);line-height:1.7;font-style:italic;margin-bottom:10px;}
.landing-testi-author{font-size:11px;font-weight:700;color:var(--accent);}
.landing-footer{text-align:center;padding:28px;border-top:1px solid var(--border);font-size:10px;color:var(--text3);letter-spacing:2px;text-transform:uppercase;}

/* WELCOME */
.welcome-block{padding:14px 16px;background:var(--surface2);border-radius:14px;border:1px solid var(--border);margin-bottom:10px;}
.welcome-block-title{font-size:10px;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:7px;}
.welcome-block p{font-size:13px;color:var(--text2);line-height:1.7;margin-bottom:5px;}
.welcome-reminder{padding:9px 13px;border-left:3px solid var(--accent);background:rgba(139,107,177,.07);border-radius:0 9px 9px 0;margin-bottom:6px;font-size:12px;color:var(--text);line-height:1.6;}
.photo-circle{width:90px;height:90px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:28px;color:white;overflow:hidden;border:3px solid var(--border2);}

/* INSTALL BUTTON (PWA) */
#install-btn{display:none;}
#install-btn.show{display:flex;}

/* COPYRIGHT */
.copyright{text-align:center;padding:13px;font-size:10px;color:var(--text3);letter-spacing:2px;text-transform:uppercase;border-top:1px solid var(--border);}

/* ── FLASHCARDS ── */
.deck-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:12px;margin-bottom:20px;}
.deck-card{border-radius:18px;padding:18px 16px;cursor:pointer;transition:all .3s cubic-bezier(.34,1.56,.64,1);position:relative;border:none;color:white;min-height:110px;display:flex;flex-direction:column;justify-content:space-between;}
.deck-card:hover{transform:translateY(-4px) scale(1.02);box-shadow:0 16px 40px rgba(0,0,0,.2);}
.deck-card-title{font-size:13px;font-weight:700;line-height:1.3;margin-bottom:4px;}
.deck-card-count{font-size:10px;opacity:.8;text-transform:uppercase;letter-spacing:1px;}
.deck-card-badge{position:absolute;top:10px;right:10px;background:rgba(255,255,255,.22);padding:2px 8px;border-radius:10px;font-size:9px;font-weight:700;}
.deck-card-official{background:rgba(255,255,255,.15);border:1px dashed rgba(255,255,255,.35);}
.deck-card-add{background:var(--surface2);border:2px dashed var(--border2) !important;color:var(--text3) !important;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:6px;font-size:12px;transition:all .25s;}
.deck-card-add:hover{border-color:var(--accent) !important;color:var(--accent) !important;background:rgba(139,107,177,.05);}

/* Card flip animation */
.fc-scene{perspective:1000px;width:100%;max-width:480px;margin:0 auto 20px;height:240px;}
.fc-card-3d{width:100%;height:100%;position:relative;transform-style:preserve-3d;transition:transform .55s cubic-bezier(.4,.2,.2,1);cursor:pointer;}
.fc-card-3d.flipped{transform:rotateY(180deg);}
.fc-face{position:absolute;width:100%;height:100%;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:20px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:28px 24px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.12);}
.fc-front{background:var(--surface);border:1.5px solid var(--border2);}
.fc-back{background:linear-gradient(135deg,var(--accent),var(--accent2));transform:rotateY(180deg);}
.fc-face-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:14px;opacity:.55;}
.fc-face-text{font-size:15px;font-weight:600;line-height:1.6;color:var(--text);}
.fc-back .fc-face-label{color:rgba(255,255,255,.7);}
.fc-back .fc-face-text{color:white;font-size:13px;font-weight:500;}
.fc-hint{text-align:center;font-size:11px;color:var(--text3);margin-bottom:16px;display:flex;align-items:center;justify-content:center;gap:6px;}
.fc-hint-dot{width:5px;height:5px;border-radius:50%;background:var(--border2);animation:fcpulse 2s ease-in-out infinite;}
@keyframes fcpulse{0%,100%{opacity:.4;}50%{opacity:1;}}
.fc-controls{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:4px;}
.fc-btn-wrong{background:rgba(196,112,106,.1);color:#B85550;border:1.5px solid rgba(196,112,106,.2);padding:10px 22px;border-radius:12px;font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;}
.fc-btn-wrong:hover{background:#B85550;color:white;}
.fc-btn-ok{background:rgba(74,156,106,.1);color:#3A7A52;border:1.5px solid rgba(74,156,106,.2);padding:10px 22px;border-radius:12px;font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;}
.fc-btn-ok:hover{background:#4A9C6A;color:white;}
.fc-progress-bar{height:4px;background:var(--surface3);border-radius:4px;margin-bottom:20px;overflow:hidden;}
.fc-progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:4px;transition:width .4s ease;}
.fc-counter{font-size:12px;color:var(--text3);text-align:center;margin-bottom:12px;}
.fc-score-ring{width:80px;height:80px;margin:0 auto 12px;position:relative;}
.fc-result-val{font-family:'Cormorant Garamond',serif;font-size:28px;color:var(--accent);text-align:center;}
/* ══════════════════════════════════════════════
   SŌMA v9 — New CSS
   ══════════════════════════════════════════════ */

/* ── MORE MENU ── */
.more-menu-overlay{position:fixed;inset:0;z-index:90;display:none;}
.more-menu-overlay.open{display:block;}
.more-menu{position:fixed;bottom:82px;left:50%;transform:translateX(-50%);background:var(--surface);border-radius:24px;border:1px solid var(--border2);padding:16px;box-shadow:var(--shadow-lg);z-index:91;display:none;min-width:280px;animation:moreIn .35s cubic-bezier(.34,1.56,.64,1);}
.more-menu.open{display:block;}
@keyframes moreIn{from{opacity:0;transform:translateX(-50%) translateY(20px) scale(.95);}to{opacity:1;transform:translateX(-50%) translateY(0) scale(1);}}
.more-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.more-item{background:var(--surface2);border-radius:16px;border:1px solid var(--border);padding:14px 12px;cursor:pointer;text-align:center;transition:all .25s;}
.more-item:hover{background:var(--surface3);border-color:var(--accent);transform:translateY(-2px);}
.more-item-icon{font-size:22px;margin-bottom:6px;}
.more-item-svg{width:22px;height:22px;margin:0 auto 6px;}
.more-item-label{font-size:11px;font-weight:700;color:var(--text);}
.more-item-sub{font-size:9px;color:var(--text3);margin-top:2px;}

/* ── DASHBOARD REFONTE ── */
.dash-calendar-widget{background:var(--surface);border-radius:20px;border:1px solid var(--border);padding:18px;margin-bottom:14px;box-shadow:var(--shadow);}
.dash-cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.dash-cal-month{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--text);font-weight:400;}
.dash-cal-nav{background:var(--surface2);border:1px solid var(--border);border-radius:50%;width:28px;height:28px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;color:var(--text2);transition:all .2s;}
.dash-cal-nav:hover{background:var(--surface3);}
.dash-cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;}
.dash-cal-day-label{font-size:9px;font-weight:700;color:var(--text3);text-align:center;padding:3px 0;text-transform:uppercase;letter-spacing:.5px;}
.dash-cal-cell{aspect-ratio:1;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;color:var(--text2);cursor:pointer;transition:all .2s;position:relative;}
.dash-cal-cell:hover{background:var(--surface2);}
.dash-cal-cell.today{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;font-weight:700;}
.dash-cal-cell.has-event::after{content:'';position:absolute;bottom:2px;left:50%;transform:translateX(-50%);width:4px;height:4px;border-radius:50%;background:var(--accent2);}
.dash-cal-cell.today.has-event::after{background:white;}
.dash-cal-cell.other-month{color:var(--border2);}
.dash-mood-row{display:flex;gap:8px;align-items:center;margin-top:14px;padding-top:14px;border-top:1px solid var(--border);}
.dash-mood-label{font-size:11px;color:var(--text3);font-weight:600;flex-shrink:0;}
.mood-btn{font-size:20px;cursor:pointer;opacity:.4;transition:all .2s;border:none;background:transparent;padding:2px 4px;}
.mood-btn:hover{opacity:.8;transform:scale(1.15);}
.mood-btn.active{opacity:1;transform:scale(1.2);}
.dash-deco-zone{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;}
.deco-img{width:80px;height:80px;border-radius:14px;object-fit:cover;border:1px solid var(--border);position:relative;}
.deco-del{position:absolute;top:-6px;right:-6px;width:18px;height:18px;background:#B85550;border-radius:50%;color:white;font-size:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;border:2px solid var(--surface);}
.deco-add{width:80px;height:80px;border-radius:14px;border:2px dashed var(--border2);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:4px;font-size:10px;color:var(--text3);cursor:pointer;transition:all .25s;}
.deco-add:hover{border-color:var(--accent);color:var(--accent);}

/* ── AGENDA STUDENT PLANNER ── */
.planner-wrap{min-height:calc(100vh - 160px);}
.planner-tabs-outer{display:flex;gap:0;overflow-x:auto;padding-bottom:2px;margin-bottom:0;scrollbar-width:none;}
.planner-tabs-outer::-webkit-scrollbar{display:none;}
.planner-tab{flex-shrink:0;padding:10px 18px;font-size:11px;font-weight:700;cursor:pointer;border:none;font-family:'Nunito',sans-serif;border-bottom:3px solid transparent;background:transparent;color:var(--text3);transition:all .25s;position:relative;white-space:nowrap;}
.planner-tab.active{color:var(--text);border-bottom-color:var(--accent);}
.planner-tab-bookmark{width:10px;height:14px;border-radius:2px 2px 0 0;position:absolute;top:-2px;left:50%;transform:translateX(-50%);opacity:0;transition:opacity .2s;}
.planner-tab.active .planner-tab-bookmark{opacity:1;}
.planner-page{display:none;padding:16px 0;}
.planner-page.active{display:block;opacity:1;animation:pageIn .35s cubic-bezier(.34,1.56,.64,1);}
.planner-section-title{font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--text);margin-bottom:14px;font-weight:400;}
.planner-section-title em{color:var(--accent);font-style:italic;}
/* Mood mini tracker on each page */
.page-mood{display:flex;align-items:center;gap:6px;padding:10px 14px;background:var(--surface2);border-radius:12px;margin-bottom:16px;}
.page-mood-label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;font-weight:700;}

/* Exam dates */
.exam-item{display:flex;align-items:center;gap:12px;padding:12px 14px;background:var(--surface);border-radius:14px;border:1px solid var(--border);margin-bottom:8px;transition:all .25s;}
.exam-item:hover{border-color:var(--border2);transform:translateX(3px);}
.exam-date-badge{background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:10px;padding:6px 10px;text-align:center;min-width:52px;flex-shrink:0;}
.exam-date-day{font-family:'Cormorant Garamond',serif;font-size:22px;color:white;line-height:1;}
.exam-date-month{font-size:9px;color:rgba(255,255,255,.8);text-transform:uppercase;letter-spacing:.5px;}
.exam-days-left{font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;}
.exam-days-left.urgent{background:rgba(196,112,106,.12);color:#B85550;}
.exam-days-left.soon{background:rgba(200,168,74,.12);color:var(--gold);}
.exam-days-left.ok{background:rgba(100,180,130,.12);color:#4A9C6A;}

/* Finance tracker */
.finance-card{background:var(--surface);border-radius:16px;border:1px solid var(--border);padding:16px;margin-bottom:10px;}
.finance-total{font-family:'Cormorant Garamond',serif;font-size:36px;color:var(--accent);line-height:1;}
.finance-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--border);font-size:13px;}
.finance-row:last-child{border-bottom:none;}
.finance-cat{color:var(--text3);font-size:11px;text-transform:uppercase;letter-spacing:1px;}
.finance-amt{font-weight:700;color:var(--text);}
.finance-amt.neg{color:#B85550;}
.finance-amt.pos{color:#4A9C6A;}

/* Goals */
.goal-item{display:flex;align-items:flex-start;gap:10px;padding:11px 14px;background:var(--surface);border-radius:13px;border:1px solid var(--border);margin-bottom:8px;}
.goal-check{width:20px;height:20px;border-radius:50%;border:2px solid var(--border2);cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;transition:all .25s;}
.goal-check.done{background:var(--accent);border-color:var(--accent);color:white;}
.goal-progress{height:4px;background:var(--surface3);border-radius:4px;margin-top:6px;overflow:hidden;}
.goal-progress-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width .5s;}

/* ── POMODORO IMMERSIF ── */
.pomo-scene{position:relative;min-height:calc(100vh - 72px);display:flex;align-items:center;justify-content:center;overflow:hidden;background:#140828;transition:background 2.5s ease;margin:-20px -18px -8px;padding:32px 24px 80px;}
.pomo-scene.is-break{background:#20080f;}
.pomo-bg-layer{position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:0;}
.pomo-orb{position:absolute;border-radius:50%;transition:background 2.5s ease;}
.pomo-orb-1{width:380px;height:380px;top:-100px;left:-100px;animation:pomOrb1 10s ease-in-out infinite;}
.pomo-orb-2{width:300px;height:300px;bottom:-80px;right:-80px;animation:pomOrb2 13s ease-in-out infinite;}
.pomo-orb-3{width:220px;height:220px;top:45%;left:55%;animation:pomOrb3 8s ease-in-out infinite;}
@keyframes pomOrb1{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(45px,30px) scale(1.12);}}
@keyframes pomOrb2{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-38px,-28px) scale(1.09);}}
@keyframes pomOrb3{0%,100%{transform:translate(0,0) scale(1);}33%{transform:translate(-22px,22px) scale(1.18);}66%{transform:translate(18px,-16px) scale(0.88);}}
.pomo-content{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;color:white;width:100%;max-width:340px;}
.pomo-mode-badge{font-size:10px;letter-spacing:3px;text-transform:uppercase;background:rgba(255,255,255,.14);padding:5px 18px;border-radius:20px;margin-bottom:22px;backdrop-filter:blur(6px);border:1px solid rgba(255,255,255,.2);font-family:'Nunito',sans-serif;font-weight:700;}
.pomo-ring-wrap{position:relative;width:220px;height:220px;margin-bottom:18px;cursor:pointer;transition:transform .2s;}
.pomo-ring-wrap:hover{transform:scale(1.03);}
.pomo-ring-svg{transform:rotate(-90deg);}
.pomo-ring-track{fill:none;stroke:rgba(255,255,255,.12);stroke-width:6;}
.pomo-ring-arc{fill:none;stroke:rgba(255,255,255,.85);stroke-width:6;transition:stroke-dashoffset 1s linear,stroke 2.5s ease;}
.pomo-scene.is-break .pomo-ring-arc{stroke:rgba(255,190,205,.9);}
.pomo-ring-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.pomo-big-time{font-family:'Cormorant Garamond',serif;font-size:74px;font-weight:300;line-height:1;color:white;text-shadow:0 2px 24px rgba(0,0,0,.35);}
.pomo-tap-hint{font-size:10px;color:rgba(255,255,255,.45);margin-top:5px;letter-spacing:1px;font-family:'Nunito',sans-serif;}
.pomo-dots-row{display:flex;gap:9px;margin-bottom:26px;}
.pomo-dot-new{width:8px;height:8px;border-radius:50%;border:1.5px solid rgba(255,255,255,.45);transition:all .3s;}
.pomo-dot-new.done{background:rgba(255,255,255,.9);border-color:transparent;}
.pomo-dot-new.active{background:rgba(255,255,255,.5);border-color:white;transform:scale(1.4);}
.pomo-ctrls{display:flex;gap:18px;align-items:center;margin-bottom:30px;}
.pomo-ctrl{width:46px;height:46px;border-radius:50%;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;backdrop-filter:blur(6px);font-family:'Nunito',sans-serif;}
.pomo-ctrl:hover{background:rgba(255,255,255,.24);transform:scale(1.1);}
.pomo-ctrl-play{width:66px;height:66px;background:rgba(255,255,255,.24);border:1.5px solid rgba(255,255,255,.4);box-shadow:0 4px 24px rgba(0,0,0,.25);}
.pomo-ctrl-play:hover{background:rgba(255,255,255,.36);transform:scale(1.08);}
.pomo-quote-block{text-align:center;margin-bottom:22px;min-height:48px;padding:0 10px;}
.pomo-quote-text{font-size:13px;font-style:italic;color:rgba(255,255,255,.68);line-height:1.65;max-width:270px;animation:pomoQuoteIn .7s ease;}
@keyframes pomoQuoteIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}
.pomo-config-btn{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.18);color:rgba(255,255,255,.65);font-size:11px;padding:7px 20px;border-radius:20px;cursor:pointer;display:flex;align-items:center;gap:7px;transition:all .2s;font-family:'Nunito',sans-serif;font-weight:600;}
.pomo-config-btn:hover{background:rgba(255,255,255,.18);color:white;}
.pomo-spotify-btn{position:absolute;bottom:24px;left:20px;z-index:10;display:flex;align-items:center;gap:9px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.18);backdrop-filter:blur(12px);border-radius:28px;padding:9px 16px 9px 10px;cursor:pointer;transition:all .3s;text-decoration:none;color:white;}
.pomo-spotify-btn:hover{background:rgba(255,255,255,.2);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.3);}
.pomo-spotify-icon{width:32px;height:32px;border-radius:50%;background:#1DB954;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .3s;}
.pomo-spotify-btn:hover .pomo-spotify-icon{transform:scale(1.12);}
.pomo-spotify-label{display:flex;flex-direction:column;gap:1px;}
.pomo-spotify-label span:first-child{font-size:10px;font-weight:700;letter-spacing:.5px;font-family:'Nunito',sans-serif;line-height:1;}
.pomo-spotify-label span:last-child{font-size:9px;color:rgba(255,255,255,.55);font-family:'Nunito',sans-serif;letter-spacing:.3px;}
.pomo-config-panel{width:100%;background:rgba(255,255,255,.1);border-radius:20px;border:1px solid rgba(255,255,255,.15);padding:20px;margin-top:14px;backdrop-filter:blur(10px);}
.pomo-config-grid{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:18px;}
.pomo-cfg{text-align:center;background:rgba(255,255,255,.08);border-radius:14px;padding:12px 14px;min-width:82px;border:1px solid rgba(255,255,255,.12);}
.pomo-cfg-lbl{font-size:9px;text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,255,255,.5);margin-bottom:9px;font-family:'Nunito',sans-serif;font-weight:700;}
.pomo-cfg-row{display:flex;align-items:center;gap:9px;justify-content:center;font-size:15px;font-weight:700;color:white;font-family:'Nunito',sans-serif;}
.pomo-cfg-row button{width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:white;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;transition:all .15s;font-family:'Nunito',sans-serif;}
.pomo-cfg-row button:hover{background:rgba(255,255,255,.3);}
.pomo-theme-section{border-top:1px solid rgba(255,255,255,.12);padding-top:16px;}
.pomo-theme-lbl{font-size:10px;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,.45);margin-bottom:12px;text-align:center;font-family:'Nunito',sans-serif;font-weight:700;}
.pomo-themes-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
.pomo-theme-swatch{width:34px;height:34px;border-radius:50%;cursor:pointer;border:2.5px solid transparent;transition:all .2s;box-shadow:0 2px 8px rgba(0,0,0,.3);}
.pomo-theme-swatch.active{border-color:white;transform:scale(1.2);}

/* ── PODCASTS ── */
.podcast-ep{background:var(--surface);border-radius:16px;border:1px solid var(--border);padding:16px;margin-bottom:10px;cursor:pointer;transition:all .25s;display:flex;gap:14px;align-items:center;}
.podcast-ep:hover{border-color:var(--border2);transform:translateX(3px);box-shadow:var(--shadow);}
.podcast-ep.playing{border-color:var(--accent);background:var(--surface2);}
.podcast-thumb{width:56px;height:56px;border-radius:12px;object-fit:cover;flex-shrink:0;background:linear-gradient(135deg,var(--accent),var(--accent2));}
.podcast-play-btn{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;flex-shrink:0;color:white;transition:all .25s;box-shadow:0 4px 12px var(--glow);}
.podcast-ep:hover .podcast-play-btn{transform:scale(1.1);}
.podcast-ep-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:3px;}
.podcast-ep-meta{font-size:11px;color:var(--text3);}
.podcast-player{background:var(--surface);border-radius:20px;border:1px solid var(--border2);padding:20px;margin-bottom:16px;box-shadow:var(--shadow-lg);}
.podcast-player-title{font-size:14px;font-weight:700;color:var(--text);margin-bottom:4px;}
.podcast-player-sub{font-size:11px;color:var(--text3);margin-bottom:14px;}
.podcast-iframe-wrap{border-radius:14px;overflow:hidden;}

/* ── NOTIFICATIONS BADGE ── */
.notif-exam-badge{background:#B85550;color:white;border-radius:50%;width:16px;height:16px;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;position:absolute;top:-4px;right:-4px;}

/* ── FONT CHOOSER ── */
.font-picker{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0;}
.font-opt{padding:6px 14px;border-radius:20px;border:1.5px solid var(--border);background:var(--surface2);cursor:pointer;font-size:12px;color:var(--text2);transition:all .2s;}
.font-opt.active{border-color:var(--accent);background:rgba(139,107,177,.1);color:var(--accent);}

/* ── COLOR SWATCHES 15 ── */
.tab-colors{display:flex;gap:6px;flex-wrap:wrap;margin:10px 0;}
.tab-color{width:26px;height:26px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:all .2s;}
.tab-color.active{border-color:var(--text);transform:scale(1.15);}


/* ── Centrage portrait mode ── */
@media(max-width:480px){
  .landing-hero{padding:48px 16px 40px;}
  .landing-headline{font-size:26px;}
  .landing-sub{font-size:13px;}
  .landing-logo{font-size:56px;}
}
@media(max-width:360px){
  .landing-logo{font-size:44px;letter-spacing:8px;}
  .landing-headline{font-size:22px;}
  .landing-sub{font-size:12px;}
  .landing-cta{flex-direction:column;align-items:center;}
  .landing-cta .btn{width:100%;max-width:300px;justify-content:center;}
  .landing-cta{flex-direction:column;align-items:center;}
  .landing-cta button{width:100%;max-width:320px;}
}
.landing-hero > div {
  display:flex;
  flex-direction:column;
  align-items:center;
}

/* ── AGENDA IFRAME : page pleine hauteur sans padding bottom ── */
#page-agenda.active {
  overflow: hidden !important;
  padding: 0 !important;
  margin: 0 !important;
}
/* Sur desktop, l'iframe garde une hauteur fixe et se centre */
@media(min-width:1024px){
  #page-agenda.active {
    display: flex !important;
    justify-content: center;
    align-items: flex-start;
    background: var(--surface2);
    height: calc(100dvh - 60px - 72px);
  }
  #agenda-iframe {
    max-width: 480px !important;
    border-radius: 16px !important;
    box-shadow: 0 8px 40px rgba(0,0,0,.15) !important;
    margin: 0 auto !important;
    height: calc(100dvh - 60px - 72px - 24px) !important;
  }
}
@media(min-width:768px) and (max-width:1023px){
  #page-agenda.active {
    display: flex !important;
    justify-content: center;
    height: calc(100dvh - 60px - 72px);
  }
  #agenda-iframe {
    max-width: 560px !important;
    height: 100% !important;
  }
}

/* ════════════════════════════════════
   SETTINGS PANEL (panneau latéral)
   ════════════════════════════════════ */

/* Bouton nav settings */
.nav-btn.settings-nav-btn.active { color: var(--accent); }

/* Backdrop */
.settings-backdrop {
  position: fixed; inset: 0; z-index: 500;
  background: rgba(30,20,40,.38);
  backdrop-filter: blur(4px);
  opacity: 0; pointer-events: none;
  transition: opacity .35s ease;
}
.settings-backdrop.open { opacity: 1; pointer-events: auto; }

/* Panneau principal */
.settings-panel {
  position: fixed; top: 0; right: 0; bottom: 0; z-index: 501;
  width: min(380px, 94vw);
  background: var(--surface);
  box-shadow: -8px 0 40px rgba(30,20,40,.22);
  transform: translateX(100%);
  transition: transform .38s cubic-bezier(.4,.2,.2,1);
  display: flex; flex-direction: column; overflow: hidden;
}
.settings-panel.open { transform: translateX(0); }

/* Header */
.sp-header {
  display: flex; align-items: center; gap: 12px;
  padding: 18px 20px 14px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.sp-close {
  width: 32px; height: 32px; border-radius: 50%;
  border: 1.5px solid var(--border2); background: transparent;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  color: var(--text2); transition: all .2s; flex-shrink: 0;
}
.sp-close:hover { background: var(--surface3); transform: scale(1.08); }
.sp-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 600; color: var(--text); flex: 1;
}

/* Navigation sections */
.sp-nav {
  display: flex; gap: 4px;
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0; overflow-x: auto;
  scrollbar-width: none;
}
.sp-nav::-webkit-scrollbar { display: none; }
.sp-nav-btn {
  padding: 6px 14px; border-radius: 20px; border: none;
  background: transparent; cursor: pointer; white-space: nowrap;
  font-family: 'Nunito', sans-serif; font-size: 11px; font-weight: 700;
  color: var(--text3); transition: all .22s; flex-shrink: 0;
}
.sp-nav-btn.active {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  color: white; box-shadow: 0 3px 10px rgba(139,107,177,.28);
}

/* Contenu scrollable */
.sp-body {
  flex: 1; overflow-y: auto; padding: 0 0 100px;
  scrollbar-width: thin; scrollbar-color: var(--lavender) transparent;
}
.sp-body::-webkit-scrollbar { width: 3px; }
.sp-body::-webkit-scrollbar-thumb { background: var(--lavender); border-radius: 3px; }

/* Sections */
.sp-section { padding: 20px 20px 8px; }
.sp-section-title {
  font-size: 9px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--text3); margin-bottom: 14px;
}
.sp-tab { display: none; }
.sp-tab.active { display: block; }

/* Lignes paramètre */
.sp-row {
  display: flex; align-items: center; gap: 12px;
  padding: 13px 14px; border-radius: 13px;
  background: var(--surface2); margin-bottom: 8px;
  border: 1px solid var(--border); transition: all .2s; cursor: pointer;
}
.sp-row:hover { border-color: var(--border2); transform: translateX(2px); }
.sp-row-icon {
  width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.sp-row-text { flex: 1; min-width: 0; }
.sp-row-label { font-size: 13px; font-weight: 700; color: var(--text); }
.sp-row-sub   { font-size: 11px; color: var(--text3); margin-top: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sp-row-chev  { color: var(--text3); font-size: 12px; flex-shrink: 0; }
.sp-row.danger { background: rgba(184,85,80,.06); border-color: rgba(184,85,80,.18); }
.sp-row.danger .sp-row-label { color: #B85550; }
.sp-row.danger:hover { background: rgba(184,85,80,.1); }

/* Toggle switch */
.sp-toggle {
  position: relative; width: 44px; height: 24px; flex-shrink: 0;
}
.sp-toggle input { opacity: 0; width: 0; height: 0; }
.sp-toggle-track {
  position: absolute; inset: 0; border-radius: 24px;
  background: var(--surface3); transition: background .25s;
  cursor: pointer; border: 1.5px solid var(--border2);
}
.sp-toggle input:checked + .sp-toggle-track {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border-color: transparent;
}
.sp-toggle-track::after {
  content: ''; position: absolute; top: 2px; left: 2px;
  width: 18px; height: 18px; border-radius: 50%;
  background: white; transition: transform .25s;
  box-shadow: 0 2px 6px rgba(0,0,0,.18);
}
.sp-toggle input:checked + .sp-toggle-track::after {
  transform: translateX(20px);
}

/* Profile avatar large */
.sp-avatar-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 24px 20px 16px; gap: 12px;
}
.sp-avatar {
  width: 80px; height: 80px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex; align-items: center; justify-content: center;
  font-family: 'Cormorant Garamond', serif; font-size: 28px; color: white;
  cursor: pointer; overflow: hidden; position: relative;
  border: 3px solid rgba(139,107,177,.3);
  transition: transform .25s, box-shadow .25s;
}
.sp-avatar:hover { transform: scale(1.05); box-shadow: 0 6px 22px rgba(139,107,177,.3); }
.sp-avatar-overlay {
  position: absolute; inset: 0; background: rgba(0,0,0,.4);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity .2s; border-radius: 50%;
}
.sp-avatar:hover .sp-avatar-overlay { opacity: 1; }
.sp-prenom-display {
  font-family: 'Cormorant Garamond', serif; font-size: 20px;
  font-weight: 600; color: var(--text);
}
.sp-email-display { font-size: 12px; color: var(--text3); }

/* Champ éditable inline */
.sp-edit-row {
  display: flex; align-items: center; gap: 10px;
  padding: 11px 14px; border-radius: 12px;
  background: var(--surface2); margin-bottom: 8px;
  border: 1.5px solid var(--border);
}
.sp-edit-row:focus-within { border-color: var(--accent); background: var(--surface); }
.sp-edit-label { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--text3); min-width: 60px; }
.sp-edit-input { flex: 1; border: none; background: transparent; font-family: 'Nunito', sans-serif; font-size: 13px; color: var(--text); outline: none; }
.sp-edit-btn { padding: 4px 10px; border-radius: 8px; border: none; background: var(--accent); color: white; font-size: 10px; font-weight: 700; cursor: pointer; transition: opacity .2s; }
.sp-edit-btn:hover { opacity: .8; }

/* Palette mini-grid */
.sp-palette-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(40px,1fr)); gap: 7px; margin-top: 6px; }
.sp-palette-dot {
  width: 40px; height: 40px; border-radius: 50%; cursor: pointer;
  border: 3px solid transparent; transition: all .22s;
  box-shadow: 0 2px 8px rgba(0,0,0,.12);
}
.sp-palette-dot:hover { transform: scale(1.12); }
.sp-palette-dot.active { border-color: var(--text); transform: scale(1.15); box-shadow: 0 4px 14px rgba(0,0,0,.2); }

/* Bouton action */
.sp-btn {
  width: 100%; padding: 11px 16px; border-radius: 12px; border: none;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  color: white; font-family: 'Nunito', sans-serif; font-size: 13px;
  font-weight: 700; cursor: pointer; transition: all .22s; margin-bottom: 8px;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
.sp-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(139,107,177,.3); }
.sp-btn.ghost { background: transparent; color: var(--text2); border: 1.5px solid var(--border2); }
.sp-btn.ghost:hover { background: var(--surface2); transform: translateY(-1px); box-shadow: none; }
.sp-btn.red { background: linear-gradient(135deg, #B85550, #D4607A); }
.sp-btn.red:hover { box-shadow: 0 6px 18px rgba(184,85,80,.3); }

/* Badge "non disponible" */
.sp-badge-soon { font-size: 9px; font-weight: 700; padding: 2px 7px; border-radius: 8px; background: rgba(139,107,177,.12); color: var(--accent); letter-spacing: .5px; flex-shrink: 0; }

