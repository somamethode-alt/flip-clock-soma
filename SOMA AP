function renderBlocs(){
  const q=(document.getElementById('f-search')?.value||'').toLowerCase();
  const bf=document.getElementById('f-bloc-filter')?.value||'';
  const zone=document.getElementById('blocs-zone');if(!zone)return;
  let html='';
  Object.keys(BLOCS).forEach(bk=>{
    if(bf&&bf!==bk)return;
    const b=BLOCS[bk];
    const bfs=S.fiches.filter(f=>f.bloc===bk&&(!q||f.titre.toLowerCase().includes(q)||(f.contenu||'').toLowerCase().includes(q)));
    const open=BLOC_OPEN[bk];
    html+=`<div class="bloc-section"><div class="bloc-header" onclick="toggleBloc('${bk}')"><div class="bloc-left"><span class="pill ${b.color}">${b.label}</span><div><div class="bloc-title">${b.title}</div><div class="bloc-sub">${bfs.length} fiche${bfs.length!==1?'s':''}</div></div></div><span class="bloc-chevron ${open?'open':''}">▲</span></div>${(function(){
        if(!open) return '';
        var cards=bfs.map(function(f,i){
          return '<div class="fiche-card" draggable="true"'
            +' ondragstart="dsf(event,\''+bk+'\','+i+')"'
            +' ondragover="dov(event)"'
            +' ondrop="dpf(event,\''+bk+'\','+i+')"'
            +' ondragleave="dlf(event)">'
            +'<span class="fiche-handle">····</span>'
            +'<span class="fiche-tag" style="background:rgba(139,107,177,.1);color:var(--accent);">'+(MODS[f.module]||f.module)+'</span>'
            +'<div class="fiche-name">'+f.titre+'</div>'
            +'<div class="fiche-meta">'+f.date+'</div>'
            +(f.fileName?'<div style="font-size:10px;color:#B85550;margin-top:4px;">PDF — '+f.fileName+'</div>':'')
            +(f.contenu?'<div class="fiche-preview">'+f.contenu.substring(0,65)+(f.contenu.length>65?'...':'')+'</div>':'')
            +'<div style="display:flex;gap:5px;margin-top:9px;">'
            +'<button class="btn btn-sm" onclick="event.stopPropagation();viewFiche('+f.id+')">Consulter</button>'
            +'<button class="btn btn-sm btn-danger" onclick="event.stopPropagation();delFiche('+f.id+')">X</button>'
            +'</div></div>';
        }).join('');
        return '<div class="fiches-grid">'+cards+'<div class="fiche-card fiche-card-add" onclick="openFicheModal(\''+bk+'\')"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg><div>Ajouter ici</div></div></div>';
      })()}</div>`;
  });
  zone.innerHTML=html||'<div style="text-align:center;padding:32px;color:var(--text3);font-size:13px;">Aucune fiche. Clique sur + Fiche.</div>';
}
function toggleBloc(bk){BLOC_OPEN[bk]=!BLOC_OPEN[bk];renderBlocs();}
function viewFiche(id){
  const f=S.fiches.find(x=>x.id===id);if(!f)return;
  const b=BLOCS[f.bloc];
  document.getElementById('fv-tags').innerHTML='<span class="pill '+(b?b.color:'pill-a')+'">'+(b?b.label:f.bloc)+'</span>';
  document.getElementById('fv-titre').textContent=f.titre;
  document.getElementById('fv-meta').textContent='Creee le '+f.date;
  const ce=document.getElementById('fv-content'),fe=document.getElementById('fv-file-zone');
  if(f.contenu){ce.textContent=f.contenu;ce.style.display='block';}else ce.style.display='none';
  if(f.fileData){
