// ── État ──────────────────────────────────────────────────────────────
var ETABS_DATA=[], etabCandidatures=[], etabAF='all', etabSQ='', etabSDept='75', etabSelId=null;
var etabMap=null, etabMarkers={}, etabGeoMarker=null, etabUserPos=null, etabRouteLine=null;
var etabCandDrawerOpen=false, etabRouteActive=false, etabMapInitialized=false;

// ── Utils ─────────────────────────────────────────────────────────────
function etabAvgNote(e){return Math.round(e.avis.reduce(function(a,v){return a+v.note;},0)/e.avis.length*10)/10;}
function etabStars(n){var f=Math.round(n);return '★'.repeat(f)+'☆'.repeat(5-f);}
function etabDistKm(la1,lo1,la2,lo2){var R=6371,dLa=(la2-la1)*Math.PI/180,dLo=(lo2-lo1)*Math.PI/180,a=Math.sin(dLa/2)*Math.sin(dLa/2)+Math.cos(la1*Math.PI/180)*Math.cos(la2*Math.PI/180)*Math.sin(dLo/2)*Math.sin(dLo/2);return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));}

// ── Filtre ────────────────────────────────────────────────────────────
function etabFilt(){
  return ETABS_DATA.filter(function(e){
    var mD=!etabSDept||e.dept===etabSDept;
    var mF=etabAF==='all'||(etabAF==='ap'&&e.accept_ap)||e.type===etabAF;
    var mS=!etabSQ||e.nom.toLowerCase().includes(etabSQ)||e.addr.toLowerCase().includes(etabSQ);
    return mD&&mF&&mS;
  });
}

// ── Init carte ────────────────────────────────────────────────────────
function etabInitMap(){
  if(etabMapInitialized) return;
  if(typeof L==='undefined'){setTimeout(etabInitMap,200);return;}
  var el=document.getElementById('etab-the-map');
  if(!el||el.offsetWidth===0){setTimeout(etabInitMap,300);return;}
  etabMapInitialized=true;
  el.innerHTML='';
  etabMap=L.map('etab-the-map',{center:[48.866,2.35],zoom:12,zoomControl:false,attributionControl:true});
  L.control.zoom({position:'bottomright'}).addTo(etabMap);
  etabAddTiles();
  etabRenderMarkers();
  setTimeout(function(){if(etabMap)etabMap.invalidateSize();},200);
  setTimeout(function(){if(etabMap)etabMap.invalidateSize();},600);
}

function etabAddTiles(){
  if(!etabMap)return;
  etabMap.eachLayer(function(l){if(l._url)etabMap.removeLayer(l);});
  var dark=document.documentElement.getAttribute('data-theme')==='dark';
  if(dark){
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{attribution:'&copy; OSM &copy; CARTO',subdomains:'abcd',maxZoom:19}).addTo(etabMap);
  } else {
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',maxZoom:19}).addTo(etabMap);
  }
}

function etabRenderMarkers(){
  if(!etabMap||typeof L==='undefined')return;
  Object.values(etabMarkers).forEach(function(m){etabMap.removeLayer(m);});
  etabMarkers={};
  etabFilt().forEach(function(e){
    var avg=etabAvgNote(e);
    var isSel=e.id===etabSelId;
    var avSvg=ETAB_AVATARS[e.avatar]||ETAB_AVATARS.a1;
    var border=isSel?'3px solid var(--accent)':'2.5px solid white';
    var shadow=isSel?'0 0 0 3px rgba(139,107,177,.4),0 4px 20px rgba(0,0,0,.4)':'0 4px 16px rgba(0,0,0,.3)';
    var html='<div style="display:flex;flex-direction:column;align-items:center;">'
      +'<div style="position:relative;width:44px;height:44px;border-radius:50%;background:white;overflow:hidden;box-shadow:'+shadow+';border:'+border+';">'
      +avSvg
      +'<div style="position:absolute;bottom:-2px;right:-2px;width:16px;height:16px;border-radius:50%;background:#C9A96E;color:white;font-family:Nunito,sans-serif;font-size:7px;font-weight:800;display:flex;align-items:center;justify-content:center;border:2px solid white;">'+avg+'</div>'
      +'</div>'
      +'<div style="width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-top:9px solid white;margin-top:-1px;"></div>'
      +'</div>';
    var icon=L.divIcon({className:'',html:html,iconSize:[44,57],iconAnchor:[22,57]});
    var m=L.marker([e.lat,e.lng],{icon:icon}).addTo(etabMap);
    m.on('click',function(){etabSel(e.id);});
    etabMarkers[e.id]=m;
  });
}

// ── Géolocalisation ───────────────────────────────────────────────────
function etabGeolocate(){
  if(!navigator.geolocation){notif('Géolocalisation non disponible');return;}
  var btn=document.getElementById('etab-geoBtn');
  btn.style.opacity='.5';
  navigator.geolocation.getCurrentPosition(
    function(pos){
      btn.style.opacity='1';btn.classList.add('active');
      etabUserPos={lat:pos.coords.latitude,lng:pos.coords.longitude};
      if(etabGeoMarker&&etabMap)etabMap.removeLayer(etabGeoMarker);
      var pulse='<div style="width:18px;height:18px;border-radius:50%;background:rgba(139,107,177,.3);display:flex;align-items:center;justify-content:center;animation:etabGpulse 1.5s infinite;">'
        +'<div style="width:9px;height:9px;border-radius:50%;background:var(--accent);border:2px solid white;"></div></div>';
      etabGeoMarker=L.marker([etabUserPos.lat,etabUserPos.lng],{icon:L.divIcon({className:'',html:pulse,iconSize:[18,18],iconAnchor:[9,9]})}).addTo(etabMap);
      etabMap.flyTo([etabUserPos.lat,etabUserPos.lng],13,{animate:true,duration:1.2});
      etabRenderList();
      notif('Position trouvée !');
      if(etabSelId)document.getElementById('etab-routeBtn').classList.add('show');
    },
    function(err){
      btn.style.opacity='1';
      notif(err.code===1?'Accès refusé à la position':'Position indisponible');
    },
    {enableHighAccuracy:true,timeout:10000,maximumAge:60000}
  );
}

// ── Itinéraire ────────────────────────────────────────────────────────
function etabToggleRoute(){
  if(!etabUserPos){notif('Activez d\'abord la géolocalisation');return;}
  var e=ETABS_DATA.find(function(x){return x.id===etabSelId;});
  if(!e){notif('Sélectionnez un établissement');return;}
  if(etabRouteActive){etabClearRoute();return;}
  etabClearRoute();
  etabRouteActive=true;
  var btn=document.getElementById('etab-routeBtn');
  btn.classList.add('on');
  document.getElementById('etab-routeBtnTxt').textContent='Effacer';
  etabRouteLine=L.polyline([[etabUserPos.lat,etabUserPos.lng],[e.lat,e.lng]],{
    color:'#8B6BB1',weight:4,opacity:.85,dashArray:'8,6',lineCap:'round',lineJoin:'round'
  }).addTo(etabMap);
  etabMap.fitBounds(etabRouteLine.getBounds(),{padding:[40,40],animate:true});
  var d=etabDistKm(etabUserPos.lat,etabUserPos.lng,e.lat,e.lng);
  notif('~'+d.toFixed(1)+' km à vol d\'oiseau');
}

function etabClearRoute(){
  if(etabRouteLine&&etabMap){etabMap.removeLayer(etabRouteLine);etabRouteLine=null;}
  etabRouteActive=false;
  var btn=document.getElementById('etab-routeBtn');
  if(btn){btn.classList.remove('on');document.getElementById('etab-routeBtnTxt').textContent='Itinéraire';}
}

// ── Liste ─────────────────────────────────────────────────────────────
function etabRenderSkeleton(){
  var el=document.getElementById('etab-sbl'),h='';
  for(var i=0;i<4;i++)h+='<div class="etab-sk"><div class="etab-sk-pin"></div><div class="etab-sk-body"><div class="etab-sk-line"></div><div class="etab-sk-line short"></div><div class="etab-sk-line xshort"></div></div></div>';
  el.innerHTML=h;
}

function etabRenderList(){
  var el=document.getElementById('etab-sbl');
  if(!el)return;
  var ef=etabFilt();
  var cntEl=document.getElementById('etab-sbCountN');
  if(cntEl)cntEl.textContent=ef.length;
  var hasF=etabAF!=='all'||etabSQ!==''||etabSDept!=='';
  var clrEl=document.getElementById('etab-sbCountClr');
  if(clrEl)clrEl.style.display=hasF?'inline':'none';
  if(!ef.length){
    el.innerHTML='<div style="text-align:center;padding:28px 12px;color:var(--text3);"><div style="font-size:12px;font-weight:700;color:var(--text2);margin-bottom:6px;">Aucun résultat</div><div style="font-size:10px;line-height:1.6;">Aucun établissement ne correspond à vos critères.</div></div>';
    return;
  }
  el.innerHTML=ef.map(function(e,i){
    var avg=etabAvgNote(e),cnt=e.avis.length,s=e.id===etabSelId;
    var avSvg=ETAB_AVATARS[e.avatar]||ETAB_AVATARS.a1;
    var inCand=etabCandidatures.some(function(c){return c.id===e.id;});
    var distStr='';
    if(etabUserPos)distStr='<span class="etab-item-dist">'+etabDistKm(etabUserPos.lat,etabUserPos.lng,e.lat,e.lng).toFixed(1)+' km</span>';
    return '<div class="etab-item'+(s?' sel':'')+'" onclick="etabSel('+e.id+')" style="animation-delay:'+(i*30)+'ms">'
      +'<div class="etab-item-pin">'+etabPinSVG(avSvg,avg)+'</div>'
      +'<div class="etab-item-body">'
      +'<div class="etab-item-name">'+e.nom+'</div>'
      +'<div class="etab-item-meta"><span class="etab-item-dept">Dép. '+e.dept+'</span><span style="color:var(--border2)">·</span>'
      +'<span class="'+(e.accept_ap?'etab-item-ap':'etab-item-nap')+'">'+(e.accept_ap?'✓ AP':'✗ AP')+'</span>'
      +(distStr?'<span style="color:var(--border2)">·</span>'+distStr:'')+'</div>'
      +'<div class="etab-item-meta" style="margin-top:2px;">'
      +'<span class="etab-item-stars">'+etabStars(avg)+'</span>'
      +'<span class="etab-item-count">('+cnt+')</span>'
      +(inCand?'<span style="color:#4A9C6A;font-size:8px;font-weight:700;">✓</span>':'')
      +'</div>'
      +'</div></div>';
  }).join('');
}

function etabPinSVG(avSvg,avg){
  return '<svg width="40" height="50" viewBox="0 0 40 50" xmlns="http://www.w3.org/2000/svg">'
    +'<circle cx="20" cy="20" r="18" fill="white" stroke="rgba(139,107,177,.25)" stroke-width="1.5"/>'
    +'<image href="data:image/svg+xml;base64,'+btoa(avSvg)+'" x="2" y="2" width="36" height="36"/>'
    +'<polygon points="20,48 14,32 26,32" fill="white"/>'
    +'<circle cx="33" cy="7" r="8" fill="#C9A96E" stroke="white" stroke-width="1.5"/>'
    +'<text x="33" y="11" text-anchor="middle" font-family="Nunito,sans-serif" font-size="7" font-weight="800" fill="white">'+avg+'</text>'
    +'</svg>';
}

// ── Sélection & Détail ────────────────────────────────────────────────
function etabSel(id){
  etabSelId=id;etabClearRoute();etabRenderMarkers();etabRenderList();
  var e=ETABS_DATA.find(function(x){return x.id===id;});
  if(!e)return;
  etabRenderDet(e);
  etabCloseSB();
  if(etabMap)etabMap.panTo([e.lat,e.lng],{animate:true,duration:.5});
  var rb=document.getElementById('etab-routeBtn');
  if(etabUserPos)rb.classList.add('show');else rb.classList.remove('show');
}

function etabRenderDet(e){
  var avg=etabAvgNote(e),cnt=e.avis.length;
  var avSvg=ETAB_AVATARS[e.avatar]||ETAB_AVATARS.a1;
  var inCand=etabCandidatures.some(function(c){return c.id===e.id;});
  var dist=[0,0,0,0,0];
  e.avis.forEach(function(a){if(a.note>=1&&a.note<=5)dist[a.note-1]++;});
  var maxD=Math.max.apply(null,dist)||1;
  var barsH=[5,4,3,2,1].map(function(s){
    return '<div class="etab-det-bar-row"><span class="etab-det-bar-n">'+s+'</span><div class="etab-det-bar-track"><div class="etab-det-bar-fill" style="width:'+Math.round(dist[s-1]/maxD*100)+'%"></div></div></div>';
  }).join('');
  var avisH=e.avis.map(function(a){
    var init=a.auteur.split(' ').map(function(w){return w[0];}).join('');
    var cols=['#8B6BB1','#C97BA8','#4A9C6A','#C9A96E','#5B8FB9','#B85550'];
    return '<div class="etab-avis-item">'
      +'<div class="etab-avis-avatar" style="background:'+cols[a.auteur.charCodeAt(0)%cols.length]+'">'+init+'</div>'
      +'<div><div class="etab-avis-author">'+a.auteur+'</div>'
      +'<div class="etab-avis-stars">'+'★'.repeat(a.note)+'☆'.repeat(5-a.note)+'</div>'
      +'<div class="etab-avis-txt">"'+a.txt+'"</div></div></div>';
  }).join('');
  var d=document.getElementById('etab-det');
  d.innerHTML=
    '<div class="etab-det-top">'
      +'<div class="etab-det-av">'+avSvg+'</div>'
      +'<div style="flex:1;min-width:0"><div class="etab-det-nm">'+e.nom+'</div><div class="etab-det-addr">'+e.addr+'</div></div>'
      +'<button class="etab-det-x" onclick="etabCloseDet()"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>'
    +'</div>'
    +'<div class="etab-det-chips">'
      +'<span class="etab-chip etab-c0">Dép. '+e.dept+'</span>'
      +'<span class="etab-chip etab-c0">'+e.type+'</span>'
      +(e.accept_ap?'<span class="etab-chip etab-cg">✓ Accepte AP</span>':'<span class="etab-chip etab-cr">✗ N\'accepte pas AP</span>')
    +'</div>'
    +'<div class="etab-det-rating">'
      +'<div class="etab-det-big-note">'+avg+'</div>'
      +'<div><div class="etab-det-stars-big">'+etabStars(avg)+'</div><div class="etab-det-reviews-count">'+cnt+' avis</div></div>'
      +'<div class="etab-det-bars">'+barsH+'</div>'
    +'</div>'
    +'<div class="etab-det-avis-list"><div class="etab-det-avis-ttl">Avis de la communauté</div>'+avisH+'</div>'
    +'<div class="etab-det-btns">'
      +'<button class="etab-dbtn etab-dbtn-g" onclick="window.open(\'mailto:'+e.email+'\')">'
        +'<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>Email'
      +'</button>'
      +'<button class="etab-dbtn etab-dbtn-p'+(inCand?' added':'')+'" onclick="etabToggleCand('+e.id+')">'
        +(inCand?'<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>Retirer':'<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Ajouter')
      +'</button>'
    +'</div>';
  d.classList.add('open');
}

function etabCloseDet(){
  document.getElementById('etab-det').classList.remove('open');
  etabSelId=null;etabClearRoute();etabRenderMarkers();etabRenderList();
  document.getElementById('etab-routeBtn').classList.remove('show');
}

// ── Candidatures ──────────────────────────────────────────────────────
function etabToggleCand(id){
  var e=ETABS_DATA.find(function(x){return x.id===id;});if(!e)return;
  var idx=etabCandidatures.findIndex(function(c){return c.id===id;});
  if(idx===-1){etabCandidatures.push(e);notif(e.nom+' ajouté !');}
  else{etabCandidatures.splice(idx,1);notif(e.nom+' retiré.');}
  etabUpdateCandBadge();etabRenderDet(e);etabRenderList();
  if(etabCandDrawerOpen)etabRenderCandDrawer();
}
function etabUpdateCandBadge(){
  var b=document.getElementById('etab-candBadge'),n=etabCandidatures.length;
  if(!b)return;
  b.textContent=n;b.style.display=n>0?'flex':'none';
}
function etabToggleCandDrawer(){
  etabCandDrawerOpen=!etabCandDrawerOpen;
  document.getElementById('etab-candDrawer').classList.toggle('open',etabCandDrawerOpen);
  if(etabCandDrawerOpen)etabRenderCandDrawer();
}
function etabRenderCandDrawer(){
  var list=document.getElementById('etab-candDrList');if(!list)return;
  if(!etabCandidatures.length){list.innerHTML='<div style="padding:16px;text-align:center;font-size:11px;color:var(--text3);">Aucune candidature.</div>';return;}
  list.innerHTML=etabCandidatures.map(function(e){
    return '<div class="etab-cand-dr-item">'
      +'<div style="width:28px;height:28px;flex-shrink:0;">'+(ETAB_AVATARS[e.avatar]||ETAB_AVATARS.a1)+'</div>'
      +'<div style="flex:1;min-width:0;"><div class="etab-cand-dr-name">'+e.nom+'</div><div class="etab-cand-dr-type">'+e.type+' · Dép. '+e.dept+'</div></div>'
      +'<button class="etab-cand-dr-del" onclick="etabToggleCand('+e.id+')">'
        +'<svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'
      +'</button></div>';
  }).join('');
}
document.addEventListener('click',function(ev){
  var p=document.getElementById('etab-candPanel');
  if(etabCandDrawerOpen&&p&&!p.contains(ev.target)){etabCandDrawerOpen=false;var d=document.getElementById('etab-candDrawer');if(d)d.classList.remove('open');}
});

// ── Filtres ───────────────────────────────────────────────────────────
function etabSetF(f,btn){
  etabAF=f;
  document.querySelectorAll('.etab-fp').forEach(function(c){c.classList.remove('on');});
  btn.classList.add('on');
  etabRenderMarkers();etabRenderList();
}
function etabDoSearch(q){etabSQ=q.toLowerCase();etabRenderMarkers();etabRenderList();}
function etabSetDept(d){etabSDept=d;etabRenderMarkers();etabRenderList();}
function etabResetFilters(){
  etabSQ='';etabAF='all';etabSDept='';
  var sq=document.getElementById('etab-sq');if(sq)sq.value='';
  var ds=document.getElementById('etab-deptSel');if(ds)ds.value='';
  document.querySelectorAll('.etab-fp').forEach(function(c){c.classList.remove('on');});
  var all=document.querySelector('.etab-fp[data-f="all"]');if(all)all.classList.add('on');
  etabRenderMarkers();etabRenderList();
}

// ── Mobile sidebar ────────────────────────────────────────────────────
function etabOpenSB(){
  document.getElementById('etab-sb').classList.add('open');
  document.getElementById('etab-mov').classList.add('show');
}
function etabCloseSB(){
  document.getElementById('etab-sb').classList.remove('open');
  document.getElementById('etab-mov').classList.remove('show');
}

// ── Initialisation page Étabs ─────────────────────────────────────────
function etabInit(){
  if(ETABS_DATA.length===0) ETABS_DATA = ETAB_RAW;
  etabRenderSkeleton();
  etabEnsureLeaflet(function(){
    etabRenderList();
    setTimeout(etabInitMap, 100);
  });
}
</script>
</body>
</html>
